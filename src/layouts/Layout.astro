---
import Preloader from "../components/Preloader.astro";
import Header from "../components/Header.astro";
import { getAssetUrl } from "../utils/cdn";

const site = Astro.site ?? new URL("https://www.acmvit.in");
const canonicalUrl = new URL(Astro.url.pathname, site);
const ogImageUrl = new URL("/opengraph.png", site);

const title = "ACM-VIT";
const description =
  "ACM-VIT is the official student chapter of the Association for Computing Machinery at VIT Vellore, focused on building impactful technology, encouraging innovation, and growing a collaborative student community.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={getAssetUrl("/favicon.webp")} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl.toString()} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ACM-VIT" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:image" content={ogImageUrl.toString()} />
    <meta property="og:image:secure_url" content={ogImageUrl.toString()} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="ACM-VIT" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl.toString()} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Preloader />
    <div
      class="diamond-grid"
      style={`background-image: url('${getAssetUrl("/background_pattern.webp")}');`}
    >
    </div>
    <img
      src={getAssetUrl("/acm_topleft.webp")}
      alt="ACM-VIT"
      class="acm-logo"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <div class="app-root min-h-screen flex flex-col">
      <Header />
      <main class="content flex-1 relative pt-28">
        <slot />
      </main>
    </div>
    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      const isCoarsePointer = window.matchMedia("(pointer: coarse)").matches;

      ScrollTrigger.config({
        limitCallbacks: true,
        ignoreMobileResize: true,
        autoRefreshEvents: "visibilitychange,DOMContentLoaded,load",
      });

      const refreshHard = () => {
        // Always measure triggers NOW
        ScrollTrigger.refresh(true);
      };

      const kickRefresh = () => {
        refreshHard();
        setTimeout(refreshHard, 250);
        setTimeout(refreshHard, 900);
      };

      if (document.readyState === "complete") {
        kickRefresh();
      } else {
        window.addEventListener("load", kickRefresh, { once: true });
      }

      if (document.fonts?.ready) {
        document.fonts.ready.then(() => {
          refreshHard();
          setTimeout(refreshHard, 250);
        });
      }

      let refreshTimeout = 0;
      const scheduleRefresh = () => {
        clearTimeout(refreshTimeout);
        refreshTimeout = window.setTimeout(refreshHard, 150);
      };

      window.addEventListener("resize", scheduleRefresh, { passive: true });
      window.addEventListener("orientationchange", scheduleRefresh, {
        passive: true,
      });

      let updateRafId = 0;
      const scheduleUpdate = () => {
        cancelAnimationFrame(updateRafId);
        updateRafId = requestAnimationFrame(() => ScrollTrigger.update());
      };

      window.addEventListener("scroll", scheduleUpdate, { passive: true });

      if (isCoarsePointer) {
        document.addEventListener("touchstart", scheduleUpdate, {
          passive: true,
        });
        document.addEventListener("touchmove", scheduleUpdate, {
          passive: true,
        });
        document.addEventListener("touchend", scheduleUpdate, {
          passive: true,
        });
      }
    </script>

    <script>
      (() => {
        const mountVariants = () => {
          const hosts = document.querySelectorAll("[data-variant-host]");
          if (!hosts.length) return;

          const defaultQuery = "(max-width: 768px), (pointer: coarse)";

          let mountedAny = false;

          hosts.forEach((host) => {
            const element = host as HTMLElement;
            const query = element.dataset.variantQuery || defaultQuery;
            const isMobile = window.matchMedia(query).matches;
            const variant = isMobile ? "mobile" : "desktop";
            if (element.dataset.variantReady === variant) return;

            const template = element.querySelector(
              `template[data-variant="${variant}"]`
            ) as HTMLTemplateElement | null;
            if (!template) return;

            Array.from(element.children).forEach((child) => {
              if (child.tagName !== "TEMPLATE") {
                child.remove();
              }
            });

            element.appendChild(template.content.cloneNode(true));
            element.dataset.variantReady = variant;
            mountedAny = true;
          });

          if (mountedAny) {
            requestAnimationFrame(() => {
              window.dispatchEvent(new Event("resize"));
            });
          }
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", mountVariants);
        } else {
          mountVariants();
        }
      })();
    </script>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    overflow-x: hidden;
    position: relative;
    background: #0d0e0d;
    font-family:
      "PolySans Trial", Inter, Roboto, "Helvetica Neue", "Arial Nova",
      "Nimbus Sans", Arial, sans-serif;
    /* Hide scrollbar for Firefox */
    scrollbar-width: none;
    /* Hide scrollbar for Internet Explorer 10+ */
    -ms-overflow-style: none;
  }

  /* Hide scrollbar for Chrome, Safari and Opera */
  html::-webkit-scrollbar,
  body::-webkit-scrollbar {
    /* display: none; */
  }

  .diamond-grid {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    /* background-image moved to inline style */
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center;
    opacity: 0.5;
    z-index: 0;
    pointer-events: none;
  }

  .acm-logo {
    position: fixed;
    top: 20px;
    left: 20px;
    width: auto;
    height: 60px;
    z-index: 1000;
    pointer-events: none;
  }

  .content {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
  }

  @media screen and (max-width: 768px), (pointer: coarse) {
    .acm-logo {
      height: 45px;
      top: 15px;
      left: 15px;
    }

    .diamond-grid {
      background-size: cover;
    }
  }

  @media screen and (max-width: 480px) {
    .acm-logo {
      height: 35px;
      top: 10px;
      left: 10px;
    }

    .diamond-grid {
      background-size: cover;
    }
  }
</style>
