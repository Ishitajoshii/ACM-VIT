  <script>
    (() => {
      const mountVariants = () => {
        const hosts = document.querySelectorAll("[data-variant-host]");
        if (!hosts.length) return;

        const isMobile = window.matchMedia("(max-width: 768px)").matches;
        const variant = isMobile ? "mobile" : "desktop";

        hosts.forEach((host) => {
          const element = host as HTMLElement;
          if (element.dataset.variantReady === variant) return;

          const template = element.querySelector(
            `template[data-variant="${variant}"]`
          ) as HTMLTemplateElement | null;
          if (!template) return;

          Array.from(element.children).forEach((child) => {
            if (child.tagName !== "TEMPLATE") {
              child.remove();
            }
          });

          element.appendChild(template.content.cloneNode(true));
          element.dataset.variantReady = variant;
        });
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", mountVariants);
      } else {
        mountVariants();
      }
    })();
  </script>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    overflow-x: hidden;
    position: relative;
    background: #0d0e0d;
    font-family:
      "PolySans Trial", Inter, Roboto, "Helvetica Neue", "Arial Nova",
      "Nimbus Sans", Arial, sans-serif;
    /* Hide scrollbar for Firefox */
    scrollbar-width: none;
    /* Hide scrollbar for Internet Explorer 10+ */
    -ms-overflow-style: none;
  }

  /* Hide scrollbar for Chrome, Safari and Opera */
  html::-webkit-scrollbar,
  body::-webkit-scrollbar {
    /* display: none; */
  }

  .diamond-grid {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    /* background-image moved to inline style */
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center;
    opacity: 0.5;
    z-index: 0;
    pointer-events: none;
  }

  .acm-logo {
    position: fixed;
    top: 20px;
    left: 20px;
    width: auto;
    height: 60px;
    z-index: 1000;
    pointer-events: none;
  }

  .content {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
  }

  @media screen and (max-width: 768px) {
    .acm-logo {
      height: 45px;
      top: 15px;
      left: 15px;
    }

    .diamond-grid {
      background-size: cover;
    }
  }

  @media screen and (max-width: 480px) {
    .acm-logo {
      height: 35px;
      top: 10px;
      left: 10px;
    }

    .diamond-grid {
      background-size: cover;
    }
  }
</style>
