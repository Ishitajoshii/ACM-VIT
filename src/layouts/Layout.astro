---
import Preloader from "../components/Preloader.astro";
import Header from "../components/Header.astro";
import { getAssetUrl } from "../utils/cdn";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={getAssetUrl("/favicon.svg")} />
    <title>ACM-VIT</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Preloader />
    <div
      class="diamond-grid"
      style={`background-image: url('${getAssetUrl("/background_pattern.svg")}');`}
    >
    </div>
    <img src={getAssetUrl("/acm_topleft.svg")} alt="ACM-VIT" class="acm-logo" />
    <div class="app-root min-h-screen flex flex-col">
      <Header />
      <main class="content flex-1 relative pt-28">
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  @font-face {
    font-family: "PolySans Trial";
    src: url("/src/assets/fonts/PolySans-trial/PolySans-trial/Standard/PolySansTrial-Slim.otf")
      format("opentype");
    font-weight: 300;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "PolySans Trial";
    src: url("/src/assets/fonts/PolySans-trial/PolySans-trial/Standard/PolySansTrial-Neutral.otf")
      format("opentype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "PolySans Trial";
    src: url("/src/assets/fonts/PolySans-trial/PolySans-trial/Standard/PolySansTrial-Median.otf")
      format("opentype");
    font-weight: 500;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "PolySans Trial";
    src: url("/src/assets/fonts/PolySans-trial/PolySans-trial/Standard/PolySansTrial-Bulky.otf")
      format("opentype");
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    overflow-x: hidden;
    position: relative;
    background: #0d0e0d;
    font-family:
      "PolySans Trial", Inter, Roboto, "Helvetica Neue", "Arial Nova",
      "Nimbus Sans", Arial, sans-serif;
    /* Hide scrollbar for Firefox */
    scrollbar-width: none;
    /* Hide scrollbar for Internet Explorer 10+ */
    -ms-overflow-style: none;
  }

  /* Hide scrollbar for Chrome, Safari and Opera */
  html::-webkit-scrollbar,
  body::-webkit-scrollbar {
    /* display: none; */
  }

  .diamond-grid {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    /* background-image moved to inline style */
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center;
    opacity: 0.5;
    z-index: 0;
    pointer-events: none;
  }

  .acm-logo {
    position: fixed;
    top: 20px;
    left: 20px;
    width: auto;
    height: 60px;
    z-index: 1000;
    pointer-events: none;
  }

  .content {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
  }

  @media screen and (max-width: 768px) {
    .acm-logo {
      height: 45px;
      top: 15px;
      left: 15px;
    }

    .diamond-grid {
      background-size: cover;
    }
  }

  @media screen and (max-width: 480px) {
    .acm-logo {
      height: 35px;
      top: 10px;
      left: 10px;
    }

    .diamond-grid {
      background-size: cover;
    }
  }
</style>
