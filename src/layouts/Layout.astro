---
import '../styles/global.css'
--- 

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>ACM-VIT</title>
	</head>
	<body>
		<div class="diamond-grid"></div>
		<img src="/acm_topleft.svg" alt="ACM-VIT" class="acm-logo" />
		<div class="content">
			<slot />
		</div>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		overflow-x: hidden;
		position: relative;
		background: #0D0E0D;
	}
	@font-face {
  		font-family: 'PlySans';
  		src: url('/PolySans-trial/PolySans-trial/Standard/PolySansTrial-Bulky.otf') format('opentype');
  		font-weight: normal;
  		font-style: normal;
	}
	.diamond-grid {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: url('/diamond.svg');
		background-repeat: repeat;
		background-size: 40px 40px;
		opacity: 0.05;
		z-index: 1000;
		pointer-events: none;
	}

	.acm-logo {
		position: fixed;
		top: 20px;
		left: 20px;
		width: auto;
		height: 60px;
		z-index: 1000;
		pointer-events: none;
	}

	.content {
		position: relative;
		z-index: 1;
		width: 100%;
		height: 100%;
	}
	
	@media screen and (max-width: 768px) {
		.acm-logo {
			height: 45px;
			top: 15px;
			left: 15px;
		}
		
		.diamond-grid {
			background-size: 35px 35px;
		}
	}

	@media screen and (max-width: 480px) {
		.acm-logo {
			height: 35px;
			top: 10px;
			left: 10px;
		}
		
		.diamond-grid {
			background-size: 30px 30px;
		}
	}
</style>
