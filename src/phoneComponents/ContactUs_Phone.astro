---
import { getAssetUrl } from "../utils/cdn";
const fallbackEmail = "hello@acmvit.in";
const rawEndpoint = (import.meta.env.PUBLIC_CONTACT_ENDPOINT ?? "").trim();
const formAction = rawEndpoint ? undefined : `mailto:${fallbackEmail}`;
---

<section class="w-full px-4 py-12">
  <div
    class="mx-auto max-w-xl rounded-[32px] border border-white/15 bg-white/[0.04] p-6 text-white shadow-[0_15px_45px_rgba(0,0,0,0.45)]"
  >
    <div class="mb-5 text-center">
      <p class="text-xs uppercase tracking-[0.45em] text-white/60">
        Say Hello!
      </p>
      <h3 class="text-3xl font-semibold">Let's connect.</h3>
      <p class="mt-2 text-sm text-white/70">
        Prefer mail? Reach us at <span class="font-semibold"
          >hello@acmvit.in</span
        >.
      </p>
    </div>

    <form
      class="flex flex-col gap-4 text-sm"
      method="POST"
      id="contact-form-mobile"
    >
      <div class="flex flex-col gap-4 sm:flex-row sm:gap-3">
        <label
          class="flex flex-col gap-2 text-xs font-semibold uppercase tracking-[0.35em] text-white/60"
        >
          First Name
          <input
            type="text"
            name="firstName"
            required
            class="rounded-2xl border-2 border-dashed border-white/35 bg-transparent px-4 py-3 text-base text-white outline-none transition focus:border-[#F95F4A]"
          />
        </label>
        <label
          class="flex flex-col gap-2 text-xs font-semibold uppercase tracking-[0.35em] text-white/60"
        >
          Last Name
          <input
            type="text"
            name="lastName"
            class="rounded-2xl border-2 border-dashed border-white/35 bg-transparent px-4 py-3 text-base text-white outline-none transition focus:border-[#F95F4A]"
          />
        </label>
      </div>

      <label
        class="flex flex-col gap-2 text-xs font-semibold uppercase tracking-[0.35em] text-white/60"
      >
        Email
        <input
          type="email"
          name="email"
          required
          class="rounded-2xl border-2 border-dashed border-white/35 bg-transparent px-4 py-3 text-base text-white outline-none transition focus:border-[#F95F4A]"
        />
      </label>

      <label
        class="flex flex-col gap-2 text-xs font-semibold uppercase tracking-[0.35em] text-white/60"
      >
        Phone
        <input
          type="tel"
          name="phone"
          inputmode="tel"
          pattern="^[0-9+()\s-]{7,}$"
          class="rounded-2xl border-2 border-dashed border-white/35 bg-transparent px-4 py-3 text-base text-white outline-none transition focus:border-[#F95F4A]"
        />
      </label>

      <label
        class="flex flex-col gap-2 text-xs font-semibold uppercase tracking-[0.35em] text-white/60"
      >
        Message
        <textarea
          name="message"
          rows="4"
          required
          class="rounded-2xl border-2 border-dashed border-white/35 bg-transparent px-4 py-3 text-base text-white outline-none transition focus:border-[#F95F4A]"
        ></textarea>
      </label>

      <fieldset
        class="rounded-[26px] border-2 border-dashed border-white/30 px-4 py-4"
      >
        <legend
          class="text-xs font-semibold uppercase tracking-[0.35em] text-white/60"
        >
          One-on-one mentoring session?
        </legend>
        <div class="mt-3 flex flex-wrap gap-3">
          <label
            class="inline-flex items-center gap-2 rounded-full border border-white/40 px-4 py-2 text-sm font-medium text-white"
          >
            <input
              type="radio"
              name="sessionPreference"
              value="yes"
              class="accent-[#F95F4A]"
              required
            />
            Yes, please
          </label>
          <label
            class="inline-flex items-center gap-2 rounded-full border border-white/40 px-4 py-2 text-sm font-medium text-white"
          >
            <input
              type="radio"
              name="sessionPreference"
              value="no"
              class="accent-[#F95F4A]"
            />
            Not right now
          </label>
        </div>
      </fieldset>

      <button
        type="submit"
        class="mt-2 inline-flex items-center justify-center rounded-full border border-white/60 px-8 py-3 text-lg font-semibold uppercase tracking-[0.35em] text-white transition hover:bg-white/10"
      >
        Submit
      </button>
      <p
        class="text-center text-xs uppercase tracking-[0.35em] text-white/60"
        data-form-status
      >
        Typically replies within 2 business days.
      </p>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById(
    "contact-form-mobile"
  ) as HTMLFormElement;
  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]');
      const statusMsg = form.querySelector("[data-form-status]");
      const originalBtnText = submitBtn ? submitBtn.innerHTML : "Submit";

      if (submitBtn) {
        submitBtn.innerHTML = "Sending...";
        (submitBtn as HTMLButtonElement).disabled = true;
      }

      const formData = new FormData(form);
      // Handle radio buttons specifically if needed, but Object.fromEntries handles it if checked
      const data = Object.fromEntries(formData.entries());

      try {
        const response = await fetch("/api/contact", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(data),
        });

        if (response.ok) {
          if (statusMsg) statusMsg.textContent = "Message sent successfully!";
          form.reset();
          // Reset status message after a few seconds
          setTimeout(() => {
            if (statusMsg)
              statusMsg.textContent =
                "Typically replies within 2 business days.";
          }, 5000);
        } else {
          const resData = await response.json();
          if (statusMsg)
            statusMsg.textContent = `Failed: ${resData.message || "Error"}`;
        }
      } catch (error) {
        console.error("Error:", error);
        if (statusMsg)
          statusMsg.textContent = "An error occurred. Please try again.";
      } finally {
        if (submitBtn) {
          submitBtn.innerHTML = originalBtnText;
          (submitBtn as HTMLButtonElement).disabled = false;
        }
      }
    });
  }
</script>
