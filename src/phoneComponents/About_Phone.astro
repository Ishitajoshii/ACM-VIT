---
import { getAssetUrl } from "../utils/cdn";
---

<!-- About Sections for Phone -->
<div class="w-full overflow-hidden">
  <!-- About Section 1 -->
  <section
    class="about-section-phone section-1 w-full h-screen relative flex flex-col justify-center px-4 py-8 overflow-hidden bg-center bg-cover bg-no-repeat radial-overlay"
    style={{
      backgroundImage: `url(${getAssetUrl("/about/about-acmvit.jpeg")})`,
    }}
  >
    <div
      class="content-wrapper flex flex-col items-center justify-center h-full gap-4"
    >
      <div class="text-container-phone text-white p-4 text-right">
        <p class="text-[0.8rem] leading-[1.4]">
          ACM-VIT is a student chapter of the Association for Computing
          Machinery at Vellore Institute of Technology. Since our inception,
          we've been at the forefront of technological innovation and education
          on campus. Our chapter focuses on fostering a passion for computing
          through workshops, hackathons, and industry collaborations. We provide
          students with opportunities to expand their technical skills, work on
          real-world projects, and connect with industry professionals, creating
          a vibrant community of future tech leaders.
        </p>
      </div>
      <div
        class="svg-container-phone w-full max-w-[250px] flex justify-center items-end"
      >
        <img
          src={getAssetUrl("/about/Cassette.svg")}
          alt="Cassette 1"
          class="cassette-svg-phone w-full h-auto origin-center drop-shadow-[0_10px_20px_rgba(0,0,0,0.5)] will-change-[transform]"
        />
      </div>
    </div>
  </section>

  <!-- About Section 2 -->
  <section
    class="about-section-phone section-2 w-full h-screen relative flex flex-col justify-center px-4 py-8 overflow-hidden bg-center bg-cover bg-no-repeat radial-overlay"
    style={{ backgroundImage: `url(${getAssetUrl("/about/about-vit.jpeg")})` }}
  >
    <div
      class="content-wrapper flex flex-col items-center justify-center h-full gap-4"
    >
      <div class="text-container-phone text-white p-4 text-left">
        <p class="text-[0.8rem] leading-[1.4]">
          ACM-VIT is a student chapter of the Association for Computing
          Machinery at Vellore Institute of Technology. Since our inception,
          we've been at the forefront of technological innovation and education
          on campus. Our chapter focuses on fostering a passion for computing
          through workshops, hackathons, and industry collaborations. We provide
          students with opportunities to expand their technical skills, work on
          real-world projects, and connect with industry professionals, creating
          a vibrant community of future tech leaders.
        </p>
      </div>
      <div
        class="svg-container-phone w-full max-w-[250px] flex justify-center items-end"
      >
        <img
          src={getAssetUrl("/about/3.svg")}
          alt="Cassette 2"
          class="cassette-svg-phone w-full h-auto origin-center drop-shadow-[0_10px_20px_rgba(0,0,0,0.5)] will-change-[transform]"
        />
      </div>
    </div>
  </section>

  <!-- About Section 3 -->
  <section
    class="about-section-phone section-3 w-full h-screen relative flex flex-col justify-center px-4 py-8 overflow-hidden bg-center bg-cover bg-no-repeat radial-overlay"
    style={{ backgroundImage: `url(${getAssetUrl("/about/about-acm.jpeg")})` }}
  >
    <div
      class="content-wrapper flex flex-col items-center justify-center h-full gap-4"
    >
      <div class="text-container-phone text-white p-4 text-left">
        <h2 class="text-[2.5rem] mb-4">Excellence</h2>
        <p class="text-[0.8rem] leading-[1.4]">
          Striving for excellence in everything we do, from technical projects
          to community events and educational initiatives.
        </p>
      </div>
      <div
        class="svg-container-phone w-full max-w-[250px] flex justify-center items-end"
      >
        <img
          src={getAssetUrl("/about/2.svg")}
          alt="Cassette 3"
          class="cassette-svg-phone w-full h-auto origin-center drop-shadow-[0_10px_20px_rgba(0,0,0,0.5)] will-change-[transform]"
        />
      </div>
    </div>
  </section>
</div>

<style>
  .radial-overlay {
    position: relative;
  }
  .radial-overlay::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      circle at 30% 50%,
      rgba(26, 26, 26, 0.6) 0%,
      rgba(6, 6, 6, 0.85) 70%
    );
    pointer-events: none;
    z-index: 0;
  }
  .radial-overlay > * {
    position: relative;
    z-index: 1;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initPhoneAnimations() {
    console.log("Initializing Phone Animations");
    const sections = document.querySelectorAll(".about-section-phone");

    sections.forEach((section, index) => {
      const cassette = section.querySelector(".cassette-svg-phone");

      if (cassette) {
        let xStart, xEnd, rotationEnd;

        if (index === 0) {
          // Section 1
          xStart = -100; // Reduced from -200
          xEnd = -20; // Reduced from -40
          rotationEnd = 10; // Reduced rotation
        } else if (index === 1) {
          // Section 2
          xStart = 100; // Reduced from 200
          xEnd = 25; // Reduced from 50
          rotationEnd = -10;
        } else {
          // Section 3
          xStart = -100;
          xEnd = -20;
          rotationEnd = 10;
        }

        const rotationStart = -45;

        gsap.fromTo(
          cassette,
          {
            y: 300,
            x: xStart,
            rotation: rotationStart,
          },
          {
            y: 0,
            x: xEnd,
            rotation: rotationEnd,
            duration: 1,
            ease: "power2.out",
            scrollTrigger: {
              trigger: section,
              start: "top 70%",
              end: "bottom bottom",
              scrub: 1,
              toggleActions: "play none none reverse",
            },
          }
        );
      }
    });

    // Refresh ScrollTrigger to ensure positions are correct after layout
    ScrollTrigger.refresh();
  }

  // Ensure animations init after everything (including images) is loaded
  if (document.readyState === "complete") {
    initPhoneAnimations();
  } else {
    window.addEventListener("load", initPhoneAnimations);
  }
</script>
