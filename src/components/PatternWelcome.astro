<div id="container">
	<section class="screen" id="pattern-welcome">
		<div class="content-center">
			<div class="text-box">
				<span class="highlight-text">
					Voluptate veniam aliquip nisi. Officia veniam cupidatat proident elit fugiat mollit velit eiusmod 
				</span>
				<span class="normal-text">
					dolor proident sunt. Ipsum fugiat ea consequat consequat fugiat eu eu nulla commodo duis. Minim est ea ea ut aliqua.
				</span>
			</div>
		</div>
	</section>
</div>

<style>
	@font-face {
		font-family: 'PolySans Trial';
		src: url('../assets/fonts/PolySans-trial/PolySans-trial/Mono/PolySansTrial-SlimMono.otf') format('opentype');
		font-weight: 300;
		font-style: normal;
		font-display: swap;
	}

	@font-face {
		font-family: 'PolySans Trial';
		src: url('../assets/fonts/PolySans-trial/PolySans-trial/Mono/PolySansTrial-NeutralMono.otf') format('opentype');
		font-weight: 400;
		font-style: normal;
		font-display: swap;
	}

	@font-face {
		font-family: 'PolySans Trial';
		src: url('../assets/fonts/PolySans-trial/PolySans-trial/Mono/PolySansTrial-MedianMono.otf') format('opentype');
		font-weight: 500;
		font-style: normal;
		font-display: swap;
	}

	@font-face {
		font-family: 'PolySans Trial';
		src: url('../assets/fonts/PolySans-trial/PolySans-trial/Mono/PolySansTrial-BulkyMono.otf') format('opentype');
		font-weight: 700;
		font-style: normal;
		font-display: swap;
	}

	#container {
		font-family: Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
		height: 100vh;
		width: 100%;
		overflow: hidden;
		position: relative;
		background: transparent;
	}

	.screen {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 1;
	}

	.content-center {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		height: 100%;
		padding: 0 5%;
	}

	.text-box {
		max-width: 900px;
		text-align: left;
		padding: 50px 0;
		/* Removed border and background for transparency */
	}

	.highlight-text {
		color: #F95F4A;
		font-size: 32px;
		font-family: 'PolySans Trial', Arial, sans-serif;
		font-weight: 300;
		text-transform: uppercase;
		word-wrap: break-word;
		line-height: 1.2;
		letter-spacing: -0.02em;
	}

	.normal-text {
		color: white;
		font-size: 32px;
		font-family: 'PolySans Trial', Arial, sans-serif;
		font-weight: 300;
		text-transform: uppercase;
		word-wrap: break-word;
		line-height: 1.2;
		letter-spacing: -0.02em;
	}

	/* Responsive Design */
	@media (max-width: 768px) {
		.highlight-text, .normal-text {
			font-size: 28px;
		}

		.text-box {
			padding: 30px;
		}

		.background-pattern {
			background-size: 80px 80px;
		}
	}

	@media (max-width: 480px) {
		.background-pattern {
			background-size: 60px 60px;
		}
	}
</style>
