---
// Shared bottom legends for home page
---

<div
  class="legend-pins-wrapper pointer-events-none opacity-0 transition-opacity duration-[350ms] ease-[cubic-bezier(0.25,0.1,0.25,1.0)] [&.visible]:opacity-100"
  aria-hidden="false"
>
  <!-- Left Legend -->
  <div
    class="legend-pin left-legend fixed bottom-8 z-[60] font-['PolySans_Trial',sans-serif] text-[#FEFCD9] max-w-[42vw] left-8 max-lg:bottom-7 max-md:max-w-[80vw] max-md:left-4 max-md:bottom-6"
  >
    <div class="legend-left-inner inline-flex flex-col gap-1">
      <div
        class="legend-line text-xl leading-[1.15] font-normal [text-shadow:1px_1px_2px_rgba(0,0,0,0.45)] max-xl:text-[1.05rem] max-lg:text-[0.95rem] max-[860px]:text-[0.9rem] max-md:text-[0.85rem] max-[480px]:text-[0.8rem]"
      >
        Established in&nbsp;<span class="accent text-[#F95F4A]">2009</span>.
      </div>
      <div
        class="legend-line text-xl leading-[1.15] font-normal [text-shadow:1px_1px_2px_rgba(0,0,0,0.45)] max-xl:text-[1.05rem] max-lg:text-[0.95rem] max-[860px]:text-[0.9rem] max-md:text-[0.85rem] max-[480px]:text-[0.8rem]"
      >
        Evolving ever since.
      </div>
    </div>
  </div>
  <!-- Right Legend (hidden on small screens) -->
  <div
    class="legend-pin right-legend fixed bottom-8 z-[60] font-['PolySans_Trial',sans-serif] text-[#FEFCD9] max-w-[42vw] right-8 text-right flex justify-end max-lg:bottom-7 max-md:hidden"
  >
    <div class="legend-right-inner inline-flex flex-col gap-1">
      <div
        class="legend-line text-xl leading-[1.15] font-normal [text-shadow:1px_1px_2px_rgba(0,0,0,0.45)] max-xl:text-[1.05rem] max-lg:text-[0.95rem] max-[860px]:text-[0.9rem] max-md:text-[0.85rem] max-[480px]:text-[0.8rem] whitespace-nowrap"
      >
        We're not just another <span class="accent text-[#F95F4A]"
          >tech chapter</span
        ><span class="punct text-[#FEFCD9]">.</span>
      </div>
      <div
        class="legend-line text-xl leading-[1.15] font-normal [text-shadow:1px_1px_2px_rgba(0,0,0,0.45)] max-xl:text-[1.05rem] max-lg:text-[0.95rem] max-[860px]:text-[0.9rem] max-md:text-[0.85rem] max-[480px]:text-[0.8rem] whitespace-nowrap"
      >
        We're the <span class="accent text-[#F95F4A]">conspiracy</span><span
          class="punct text-[#FEFCD9]"
        >
          that actually works.</span
        >
      </div>
    </div>
  </div>
</div>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const wrapper = document.querySelector(".legend-pins-wrapper");
  const triggerSection = document.getElementById("home");

  if (wrapper && triggerSection) {
    ScrollTrigger.create({
      trigger: triggerSection,
      start: "top 60%",
      end: "bottom 100%",
      toggleClass: { targets: wrapper, className: "visible" },
    });
  } else if (wrapper) {
    // Fallback
    wrapper.classList.add("visible");
  }
</script>
