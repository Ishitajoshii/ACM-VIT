---
import PartnerCasetteSingular from "../components/PartnerCasetteSingular.astro";
import { partners } from "../data/partnersData";
import { getAssetUrl } from "../utils/cdn";
---

<div
  id="partners-container"
  class="relative flex flex-wrap gap-6 justify-center items-center w-full pt-18 pb-64 overflow-hidden"
>
  <div
    id="Cassette-pos-1"
    class="partners-floating w-full flex justify-center mt-0 relative"
  >
    <img
      id="partners-svg"
      src={getAssetUrl("/partners-cassette.svg")}
      alt="Partners Image"
      class="max-w-[300px] md:max-w-[500px] w-auto object-contain"
      loading="lazy"
      decoding="async"
    />
  </div>

  <div
    class="partners-carousel w-[80vw] pb-24 flex flex-wrap gap-6 justify-center items-center relative z-10"
    data-partners-carousel
  >
    <div class="partners-track flex flex-wrap gap-6 justify-center items-center">
      {
        partners.map((partner) => (
          <div class="partners-card">
            <PartnerCasetteSingular
              title={partner.title}
              imageUrl={getAssetUrl(partner.imageUrl)}
              link={partner.link}
            />
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .partners-floating {
    position: fixed;
    left: 0;
    right: 0;
    bottom: -140px;
    z-index: 20;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    will-change: opacity;
  }

  .partners-floating.is-fixed {
    opacity: 1;
  }


  @media (max-width: 768px), (pointer: coarse) {
    .partners-floating {
      bottom: -110px;
    }
    .partners-carousel {
      width: 100vw;
      padding: 0 6vw 5rem;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
    }

    .partners-carousel::-webkit-scrollbar {
      display: none;
    }

    .partners-track {
      flex-wrap: nowrap;
      justify-content: flex-start;
      gap: 1.25rem;
      padding: 0.5rem 1vw;
    }

    .partners-card {
      flex: 0 0 auto;
      scroll-snap-align: center;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const pos1 = document.getElementById("Cassette-pos-1");
    const section = document.getElementById("partners");
    const gallery = document.getElementById("gallery");

    if (!pos1 || !section) return;

    let inPartners = false;
    let inGallery = false;
    const updateVisibility = () => {
      const isActive = inPartners && !inGallery;
      pos1.classList.toggle("is-fixed", isActive);
      document.body.classList.toggle("partners-active", isActive);
    };

    const partnersObserver = new IntersectionObserver(
      ([entry]) => {
        inPartners = entry.isIntersecting;
        updateVisibility();
      },
      {
        root: null,
        rootMargin: "-15% 0px -15% 0px",
        threshold: 0,
      }
    );

    partnersObserver.observe(section);

    if (gallery) {
      const galleryObserver = new IntersectionObserver(
        ([entry]) => {
          inGallery = entry.isIntersecting;
          updateVisibility();
        },
        {
          root: null,
          rootMargin: "0px 0px 0px 0px",
          threshold: 0,
        }
      );

      galleryObserver.observe(gallery);
    }

    const carousel = document.querySelector(
      "[data-partners-carousel]"
    ) as HTMLElement | null;
    const isCoarsePointer = window.matchMedia(
      "(max-width: 768px), (pointer: coarse)"
    ).matches;

    if (carousel && isCoarsePointer) {
      let isUserInteracting = false;
      let scrollRaf = 0;

      const setInteracting = (state: boolean) => {
        isUserInteracting = state;
      };

      const syncHorizontalScroll = () => {
        scrollRaf = 0;
        if (isUserInteracting) return;
        if (!section) return;
        const rect = section.getBoundingClientRect();
        const viewportHeight = window.innerHeight;
        const maxScroll = carousel.scrollWidth - carousel.clientWidth;
        if (maxScroll <= 0) return;

        const progress = Math.min(
          Math.max((viewportHeight - rect.top) / (rect.height + viewportHeight), 0),
          1
        );
        carousel.scrollLeft = maxScroll * progress;
      };

      const scheduleSync = () => {
        if (scrollRaf) return;
        scrollRaf = requestAnimationFrame(syncHorizontalScroll);
      };

      window.addEventListener("scroll", scheduleSync, { passive: true });
      window.addEventListener("resize", scheduleSync, { passive: true });

      carousel.addEventListener("pointerdown", () => setInteracting(true));
      carousel.addEventListener("pointerup", () => setInteracting(false));
      carousel.addEventListener("pointercancel", () => setInteracting(false));
      carousel.addEventListener("touchstart", () => setInteracting(true), {
        passive: true,
      });
      carousel.addEventListener("touchend", () => setInteracting(false));

      scheduleSync();
    }
  });
</script>
