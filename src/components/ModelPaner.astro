---
import modelViewerScript from './model-gsap.ts?url';
---

<div id="viewer" style="width: 100%; height: 100%;"></div>

<script type="module" src={modelViewerScript}></script>

<script>
  window.addEventListener('DOMContentLoaded', () => {
    import('./model-gsap.ts').then(module => {
      module.initViewer('viewer', '/models/MINImap.glb',{
    endScroll: 4000,
    desiredSize: 2.5,
    cameraDistanceMul: 2.0,
    startX: -3,
    endX: 3,
    showHelpers: true,
    debugMarkers: false
    });
    });
  });
</script>