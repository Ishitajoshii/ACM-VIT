
<div id="preloader" class="preloader">
  <div class="loader-content">
    <div id="lottie-container" class="lottie-container"></div>
    <div class="progress-bar">
      <div class="progress-fill"></div>
    </div>
  </div>
</div>

<script>
  const preloader = document.getElementById("preloader");
  const progressFill = document.querySelector(".progress-fill") as HTMLElement;
  const lottieContainer = document.getElementById("lottie-container");
  import { getAssetUrl } from "../utils/cdn";

  let loadingAnimation: any = null;
  let loadedAnimation: any = null;
  let progressTween: any = null;
  let gsapInstance: any = null;
  let lottieInstance: any = null;
  let progressValue = 0;
  let hasStartedCompletion = false;
  let hasFinished = false;
  let fallbackTimeoutId = 0;
  let loadingRequestId = 0;

  const getGsap = async () => {
    if (gsapInstance) return gsapInstance;
    const mod = await import("gsap");
    gsapInstance = mod.gsap || mod.default || mod;
    return gsapInstance;
  };

  const getLottie = async () => {
    if (lottieInstance) return lottieInstance;
    const mod = await import("lottie-web/build/player/lottie_light");
    lottieInstance = mod.default || mod;
    return lottieInstance;
  };

  const initPreloader = async () => {
    if (!preloader || !progressFill || !lottieContainer) return;
    const preloaderShown = sessionStorage.getItem("preloaderShown");

    if (preloaderShown) {
      preloader.style.display = "none";
      return;
    }

    const gsap = await getGsap();
    const lottie = await getLottie();

    gsap.set(preloader, { autoAlpha: 1 });
    gsap.set(progressFill, { width: "0%" });

    const updateProgress = (pct: number) => {
      const nextValue = Math.max(progressValue, Math.min(90, pct));
      if (nextValue === progressValue) return;
      progressValue = nextValue;
      if (progressTween) progressTween.kill();
      progressTween = gsap.to(progressFill, {
        width: `${nextValue}%`,
        duration: 0.2,
        ease: "power1.out",
        overwrite: "auto",
      });
    };

    const startProgress = () => {
      progressValue = 0;
      if (progressTween) progressTween.kill();
      gsap.set(progressFill, { width: "0%" });
    };

    const loadingPath = getAssetUrl("/loader/loading_state.json");
    const loadedPath = getAssetUrl("/loader/loaded_state.json");

    const loadLoadingAnimation = async () => {
      const requestId = ++loadingRequestId;
      try {
        const loadingResponse = await fetch(loadingPath);
        const loadingData = await loadingResponse.json();
        if (hasStartedCompletion || hasFinished || requestId !== loadingRequestId) return;
        loadingAnimation = lottie.loadAnimation({
          container: lottieContainer,
          renderer: "svg",
          loop: true,
          autoplay: true,
          animationData: loadingData,
        });
      } catch (error) {
        console.error("Failed to load loading animation:", error);
        if (hasStartedCompletion || hasFinished || requestId !== loadingRequestId) return;
        loadingAnimation = lottie.loadAnimation({
          container: lottieContainer,
          renderer: "svg",
          loop: true,
          autoplay: true,
          path: loadingPath,
        });
      }
    };

    const loadLoadedAnimation = async () => {
      if (hasFinished) return null;
      try {
        const loadedResponse = await fetch(loadedPath);
        const loadedData = await loadedResponse.json();
        if (hasFinished) return null;
        return lottie.loadAnimation({
          container: lottieContainer,
          renderer: "svg",
          loop: false,
          autoplay: true,
          animationData: loadedData,
        });
      } catch (error) {
        console.error("Failed to load completion animation:", error);
        if (hasFinished) return null;
        return lottie.loadAnimation({
          container: lottieContainer,
          renderer: "svg",
          loop: false,
          autoplay: true,
          path: loadedPath,
        });
      }
    };

    startProgress();
    loadLoadingAnimation();

    let windowLoaded = false;
    let assetsLoaded = false;

    const collectAssetUrls = (): { urls: string[]; imageUrls: Set<string> } => {
      const urls = new Set<string>();
      const imageUrls = new Set<string>();

      const normalizeUrl = (
        value: string | null | undefined,
        baseUrl = location.href
      ): string | null => {
        if (!value) return null;
        const trimmed = value.trim();
        if (!trimmed || trimmed.startsWith('#')) return null;
        if (trimmed.startsWith('data:') || trimmed.startsWith('blob:')) return null;
        try {
          return new URL(trimmed, baseUrl).href;
        } catch (e) {
          return trimmed;
        }
      };

      const addUrl = (
        value: string | null | undefined,
        isImage = false,
        baseUrl = location.href
      ) => {
        const normalized = normalizeUrl(value, baseUrl);
        if (!normalized) return;
        urls.add(normalized);
        if (isImage) imageUrls.add(normalized);
      };

      const addSrcset = (
        value: string | null | undefined,
        isImage = false,
        baseUrl = location.href
      ) => {
        if (!value) return;
        value
          .split(',')
          .map((entry) => entry.trim().split(/\s+/)[0])
          .filter(Boolean)
          .forEach((src) => addUrl(src, isImage, baseUrl));
      };

      const addUrlsFromStyle = (
        value: string | null | undefined,
        isImage = false,
        baseUrl = location.href
      ) => {
        if (!value || value === 'none') return;
        const matches = [...value.matchAll(/url\(["']?(.*?)["']?\)/g)];
        matches.forEach((match) => addUrl(match[1], isImage, baseUrl));
      };

      const collectFromRoot = (root: ParentNode, includeComputed = false) => {
        root.querySelectorAll('img').forEach((img) => {
          addUrl(img.getAttribute('src'), true);
          addUrl(img.getAttribute('data-src'), true);
          addSrcset(img.getAttribute('srcset'), true);
          addSrcset(img.getAttribute('data-srcset'), true);
        });

        root.querySelectorAll('source').forEach((source) => {
          addUrl(source.getAttribute('src'), true);
          addUrl(source.getAttribute('data-src'), true);
          addSrcset(source.getAttribute('srcset'), true);
          addSrcset(source.getAttribute('data-srcset'), true);
        });

        root.querySelectorAll('video').forEach((video) => {
          addUrl(video.getAttribute('src'));
          addUrl(video.getAttribute('data-src'));
          addUrl(video.getAttribute('poster'), true);
          addUrl(video.getAttribute('data-poster'), true);
        });

        root.querySelectorAll('audio').forEach((audio) => {
          addUrl(audio.getAttribute('src'));
          addUrl(audio.getAttribute('data-src'));
        });

        root.querySelectorAll('image').forEach((image) => {
          addUrl(image.getAttribute('href'), true);
          addUrl(image.getAttribute('xlink:href'), true);
        });

        root.querySelectorAll('[style]').forEach((el) => {
          addUrlsFromStyle(el.getAttribute('style'), true);
        });

        root
          .querySelectorAll(
            'link[rel="preload"], link[rel="prefetch"], link[rel="stylesheet"], link[rel="modulepreload"]'
          )
          .forEach((linkEl) => {
            addUrl(linkEl.getAttribute('href'));
          });

        root.querySelectorAll('script[src]').forEach((scriptEl) => {
          addUrl(scriptEl.getAttribute('src'));
        });

        if (includeComputed) {
          root.querySelectorAll('*').forEach((el) => {
            try {
              const style = window.getComputedStyle(el);
              if (!style) return;
              addUrlsFromStyle(style.backgroundImage, true);
              addUrlsFromStyle(style.getPropertyValue('mask-image'), true);
              addUrlsFromStyle(style.getPropertyValue('-webkit-mask-image'), true);
            } catch (e) {
            }
          });
        }
      };

      collectFromRoot(document, true);

      document.querySelectorAll('template').forEach((template) => {
        collectFromRoot(template.content, false);
      });

      Array.from(document.styleSheets).forEach((sheet) => {
        let rules: CSSRuleList | null = null;
        try {
          rules = sheet.cssRules;
        } catch (e) {
          return;
        }
        if (!rules) return;
        Array.from(rules).forEach((rule) => {
          if ('cssText' in rule) {
            addUrlsFromStyle(rule.cssText, false, sheet.href || location.href);
          }
        });
      });

      return { urls: Array.from(urls), imageUrls };
    };

    const preloadAssets = (urls: string[], imageUrls: Set<string>): Promise<boolean> => {
      return new Promise((resolve) => {
        if (!urls || urls.length === 0) return resolve(true);
        let loaded = 0;
        const total = urls.length;

        const onProgress = () => {
          loaded++;
          const pct = Math.min(90, Math.round((loaded / total) * 90));
          updateProgress(pct);
          if (loaded >= total) resolve(true);
        };

        urls.forEach((u: string) => {
          const isImage =
            imageUrls.has(u) || /\.(png|jpe?g|gif|webp|avif|svg)(\?|$)/i.test(u);
          if (isImage) {
            const img = new Image();
            img.onload = onProgress;
            img.onerror = onProgress;
            img.src = u;
          } else {
            // fetch resource to warm cache
            fetch(u, { method: 'GET', mode: 'cors', cache: 'force-cache' })
              .then(() => onProgress())
              .catch(() => onProgress());
          }
        });
      });
    };

    const waitForFonts = () => {
      if (document.fonts && document.fonts.ready) {
        return document.fonts.ready.catch(() => {});
      }
      return Promise.resolve();
    };

    const preloadAllAssets = async () => {
      try {
        const { urls, imageUrls } = collectAssetUrls();
        await Promise.all([preloadAssets(urls, imageUrls), waitForFonts()]);
      } catch (e) {
        console.warn('Asset preloading failed', e);
      }
      assetsLoaded = true;
      maybeProceed();
    };

    const maybeProceed = () => {
      if (hasStartedCompletion || hasFinished) return;
      if (windowLoaded && assetsLoaded) {
        proceedAfterAssets();
      }
    };

    const proceedAfterAssets = () => {
      if (hasStartedCompletion || hasFinished) return;
      hasStartedCompletion = true;
      loadingRequestId += 1;
      // Force progress to 100% first
      if (progressTween) progressTween.kill();
      progressTween = gsap.to(progressFill, {
        width: '100%',
        duration: 0.5,
        onComplete: () => {
          if (loadingAnimation) {
            loadingAnimation.destroy();
            loadingAnimation = null;
          }
          if (lottieContainer) {
            lottieContainer.innerHTML = "";
          }

          loadLoadedAnimation()
            .then((animation) => {
              if (!animation) {
                finishLoading();
                return;
              }
              loadedAnimation = animation;
              loadedAnimation.addEventListener('complete', finishLoading);
            })
            .catch(() => {
              finishLoading();
            });
        },
      });
    };

    preloadAllAssets();

    const onWindowLoad = () => {
      if (windowLoaded) return;
      windowLoaded = true;
      maybeProceed();
    };

    if (document.readyState === 'complete') {
      onWindowLoad();
    } else {
      window.addEventListener('load', onWindowLoad, { once: true });
    }

    // Fallback safety timeout
    fallbackTimeoutId = window.setTimeout(() => {
      if (hasStartedCompletion || hasFinished) return;
      console.warn('Preloader timeout reached - forcing dismissal');
      proceedAfterAssets();
    }, 7000);
  };

  function finishLoading() {
    const preloader = document.getElementById("preloader");
    if (!preloader || !gsapInstance || hasFinished) return;
    hasFinished = true;
    hasStartedCompletion = true;
    if (fallbackTimeoutId) window.clearTimeout(fallbackTimeoutId);
    if (loadedAnimation) {
      loadedAnimation.removeEventListener("complete", finishLoading);
    }

    const tl = gsapInstance.timeline({
      onComplete: () => {
        sessionStorage.setItem("preloaderShown", "true");
        // Clean up animations
        if (progressTween) progressTween.kill();
        if (loadingAnimation) loadingAnimation.destroy();
        if (loadedAnimation) loadedAnimation.destroy();
      },
    });

    tl.to(".progress-bar", {
      opacity: 0,
      duration: 0.3,
    })
      .to(preloader, {
        yPercent: -100,
        duration: 0.8,
        ease: "power4.inOut",
      })
      .set(preloader, { display: "none" });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => {
      void initPreloader();
    });
  } else {
    void initPreloader();
  }
</script>

<style>
  .preloader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #0d0e0d; /* Match body background */
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }

  .loader-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .lottie-container {
    width: 300px;
    height: 300px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .lottie-container svg {
    max-width: 100%;
    max-height: 100%;
  }

  .progress-bar {
    width: 300px; /* Same width as lottie container */
    height: 3px;
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 2px;
    overflow: hidden;
    position: relative;
  }

  .progress-fill {
    height: 100%;
    background: #ffffff;
    position: relative;
    width: 0%;
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-fill::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
    animation: shimmer 2s infinite;
  }

  @keyframes shimmer {
    0% {
      left: -100%;
    }
    100% {
      left: 100%;
    }
  }

  /* Responsive adjustments */
  @media (max-width: 768px), (pointer: coarse) {
    .lottie-container {
      width: 250px;
      height: 250px;
    }
    
    .progress-bar {
      width: 250px;
    }
  }

  @media (max-width: 480px) {
    .lottie-container {
      width: 200px;
      height: 200px;
    }
    
    .progress-bar {
      width: 200px;
    }
  }
</style>
