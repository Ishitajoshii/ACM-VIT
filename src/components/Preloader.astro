
<div id="preloader" class="preloader">
  <div class="loader-content">
    <div id="lottie-container" class="lottie-container"></div>
    <div class="progress-bar">
      <div class="progress-fill"></div>
    </div>
  </div>
</div>

<script>
  const preloader = document.getElementById("preloader");
  const progressFill = document.querySelector(".progress-fill") as HTMLElement;
  const lottieContainer = document.getElementById("lottie-container");
  import { getAssetUrl } from "../utils/cdn";

  let loadingAnimation: any = null;
  let loadedAnimation: any = null;
  let progressTween: any = null;
  let gsapInstance: any = null;
  let lottieInstance: any = null;
  let progressValue = 0;
  let hasStartedCompletion = false;
  let hasFinished = false;
  let fallbackTimeoutId = 0;
  let fakeProgressTimer = 0;

  const getGsap = async () => {
    if (gsapInstance) return gsapInstance;
    const mod = await import("gsap");
    gsapInstance = mod.gsap || mod.default || mod;
    return gsapInstance;
  };

  const getLottie = async () => {
    if (lottieInstance) return lottieInstance;
    const mod = await import("lottie-web/build/player/lottie_light");
    lottieInstance = mod.default || mod;
    return lottieInstance;
  };

  const setProgress = (gsap: any, nextValue: number, duration = 0.2) => {
    const clamped = Math.max(progressValue, Math.min(95, nextValue));
    if (clamped === progressValue) return;
    progressValue = clamped;
    if (progressTween) progressTween.kill();
    progressTween = gsap.to(progressFill, {
      width: `${clamped}%`,
      duration,
      ease: "power1.out",
      overwrite: "auto",
    });
  };

  const startFakeProgress = (gsap: any) => {
    if (fakeProgressTimer) window.clearInterval(fakeProgressTimer);
    fakeProgressTimer = window.setInterval(() => {
      if (hasFinished || hasStartedCompletion) return;
      const increment = progressValue < 60 ? 6 : 3;
      setProgress(gsap, progressValue + increment, 0.3);
    }, 180);
  };

  const stopFakeProgress = () => {
    if (!fakeProgressTimer) return;
    window.clearInterval(fakeProgressTimer);
    fakeProgressTimer = 0;
  };

  const waitForWindowLoad = () =>
    new Promise<void>((resolve) => {
      if (document.readyState === "complete") {
        resolve();
        return;
      }
      window.addEventListener("load", () => resolve(), { once: true });
    });

  const waitForFonts = () => {
    if (document.fonts && document.fonts.ready) {
      return document.fonts.ready.catch(() => {});
    }
    return Promise.resolve();
  };

  const loadingPath = getAssetUrl("/loader/loading_state.json");
  const loadedPath = getAssetUrl("/loader/loaded_state.json");

  const loadLoadingAnimation = async (lottie: any) => {
    if (hasFinished || hasStartedCompletion || !lottieContainer) return;
    try {
      loadingAnimation = lottie.loadAnimation({
        container: lottieContainer,
        renderer: "svg",
        loop: true,
        autoplay: true,
        path: loadingPath,
      });
    } catch (error) {
      console.warn("Failed to load loading animation", error);
    }
  };

  const loadLoadedAnimation = async (lottie: any) => {
    if (hasFinished || !lottieContainer) return null;
    try {
      return lottie.loadAnimation({
        container: lottieContainer,
        renderer: "svg",
        loop: false,
        autoplay: true,
        path: loadedPath,
      });
    } catch (error) {
      console.warn("Failed to load completion animation", error);
      return null;
    }
  };

  const proceedToCompletion = async (gsap: any, lottie: any) => {
    if (hasStartedCompletion || hasFinished) return;
    hasStartedCompletion = true;
    stopFakeProgress();
    if (fallbackTimeoutId) window.clearTimeout(fallbackTimeoutId);

    if (progressTween) progressTween.kill();
    progressTween = gsap.to(progressFill, {
      width: "100%",
      duration: 0.45,
      ease: "power1.out",
      onComplete: async () => {
        if (loadingAnimation) {
          loadingAnimation.destroy();
          loadingAnimation = null;
        }
        if (lottieContainer) {
          lottieContainer.innerHTML = "";
        }

        loadedAnimation = await loadLoadedAnimation(lottie);
        if (loadedAnimation) {
          loadedAnimation.addEventListener("complete", finishLoading);
        } else {
          finishLoading();
        }
      },
    });
  };

  const initPreloader = async () => {
    if (!preloader || !progressFill || !lottieContainer) return;
    const preloaderShown = sessionStorage.getItem("preloaderShown");

    if (preloaderShown) {
      preloader.style.display = "none";
      return;
    }

    const [gsap, lottie] = await Promise.all([getGsap(), getLottie()]);

    gsap.set(preloader, { autoAlpha: 1 });
    gsap.set(progressFill, { width: "0%" });
    progressValue = 0;

    const startTime = performance.now();

    await loadLoadingAnimation(lottie);
    startFakeProgress(gsap);

    const softTimeoutId = window.setTimeout(() => {
      void proceedToCompletion(gsap, lottie);
    }, 2200);

    fallbackTimeoutId = window.setTimeout(() => {
      void proceedToCompletion(gsap, lottie);
    }, 3500);

    await Promise.allSettled([waitForWindowLoad(), waitForFonts()]);

    const elapsed = performance.now() - startTime;
    const minimumDisplay = 600;
    const delay = Math.max(0, minimumDisplay - elapsed);

    window.setTimeout(() => {
      window.clearTimeout(softTimeoutId);
      void proceedToCompletion(gsap, lottie);
    }, delay);
  };

  function finishLoading() {
    const preloader = document.getElementById("preloader");
    if (!preloader || !gsapInstance || hasFinished) return;
    hasFinished = true;
    hasStartedCompletion = true;
    if (fallbackTimeoutId) window.clearTimeout(fallbackTimeoutId);
    if (loadedAnimation) {
      loadedAnimation.removeEventListener("complete", finishLoading);
    }

    const tl = gsapInstance.timeline({
      onComplete: () => {
        sessionStorage.setItem("preloaderShown", "true");
        // Clean up animations
        if (progressTween) progressTween.kill();
        if (loadingAnimation) loadingAnimation.destroy();
        if (loadedAnimation) loadedAnimation.destroy();
      },
    });

    tl.to(".progress-bar", {
      opacity: 0,
      duration: 0.3,
    })
      .to(preloader, {
        yPercent: -100,
        duration: 0.8,
        ease: "power4.inOut",
      })
      .set(preloader, { display: "none" });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => {
      void initPreloader();
    });
  } else {
    void initPreloader();
  }
</script>

<style>
  .preloader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #0d0e0d; /* Match body background */
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }

  .loader-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .lottie-container {
    width: 300px;
    height: 300px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .lottie-container svg {
    max-width: 100%;
    max-height: 100%;
  }

  .progress-bar {
    width: 300px; /* Same width as lottie container */
    height: 3px;
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 2px;
    overflow: hidden;
    position: relative;
  }

  .progress-fill {
    height: 100%;
    background: #ffffff;
    position: relative;
    width: 0%;
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-fill::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
    animation: shimmer 2s infinite;
  }

  @keyframes shimmer {
    0% {
      left: -100%;
    }
    100% {
      left: 100%;
    }
  }

  /* Responsive adjustments */
  @media (max-width: 768px), (pointer: coarse) {
    .lottie-container {
      width: 250px;
      height: 250px;
    }
    
    .progress-bar {
      width: 250px;
    }
  }

  @media (max-width: 480px) {
    .lottie-container {
      width: 200px;
      height: 200px;
    }
    
    .progress-bar {
      width: 200px;
    }
  }
</style>
