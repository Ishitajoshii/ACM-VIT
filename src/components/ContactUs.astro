---

---

<section class="laptop-section relative w-full h-[300vh]">
  <div
    class="sticky top-0 left-0 w-full h-screen flex items-center justify-center overflow-hidden"
  >
    <canvas
      id="laptop-canvas"
      class="w-[80%] h-[80%] object-contain brightness-125"></canvas>
    <div
      class="contact-heading absolute top-[25%] left-1/2 transform -translate-x-1/2 -translate-y-1/2 text-center z-10 opacity-100 pointer-events-none"
    >
      <div
        class="justify-start text-white text-5xl font-semibold font-['PolySans_Trial'] uppercase"
      >
        Contact us!
      </div>
    </div>

    <!-- Contact Form Overlay -->
    <div
      class="contact-form-overlay absolute top-[8%] left-[11%] w-[78%] h-[72%] z-20 opacity-0 pointer-events-none flex flex-col items-center justify-center"
    >
      <div class="flex flex-col items-center text-black mb-1">
        <div
          class="text-center justify-start text-stone-900 text-2xl font-bold font-['Nunito_Sans']"
        >
          Say Hello!
        </div>
      </div>

      <form
        class="contact-form pointer-events-auto mt-4 flex w-full max-w-[50%] flex-col gap-4 text-xs text-black px-4"
        method="POST"
        id="contact-form-desktop"
      >
        <div class="contact-grid grid gap-4 sm:grid-cols-2">
          <label
            class="flex flex-col gap-2 text-[8px] font-semibold uppercase tracking-[0.35em] text-neutral-500 sm:text-[10px]"
          >
            First Name
            <input
              type="text"
              name="firstName"
              required
              class="contact-input"
            />
          </label>
          <label
            class="flex flex-col gap-2 text-[8px] font-semibold uppercase tracking-[0.35em] text-neutral-500 sm:text-[10px]"
          >
            Last Name
            <input type="text" name="lastName" class="contact-input" />
          </label>
        </div>

        <div class="contact-grid grid gap-4 sm:grid-cols-2">
          <label
            class="flex flex-col gap-2 text-[8px] font-semibold uppercase tracking-[0.35em] text-neutral-500 sm:text-[10px]"
          >
            Email
            <input type="email" name="email" required class="contact-input" />
          </label>
          <label
            class="flex flex-col gap-2 text-[8px] font-semibold uppercase tracking-[0.35em] text-neutral-500 sm:text-[10px]"
          >
            Phone
            <input
              type="tel"
              name="phone"
              inputmode="tel"
              pattern="^[0-9+()\s-]{7,}$"
              class="contact-input"
            />
          </label>
        </div>

        <label
          class="flex flex-col gap-2 text-[8px] font-semibold uppercase tracking-[0.35em] text-neutral-500 sm:text-[10px]"
        >
          Message
          <textarea
            name="message"
            rows="2"
            required
            class="contact-input resize-none py-2.5"></textarea>
        </label>

        <div class="flex flex-col items-center gap-4 mt-4">
          <div
            class="w-40 h-10 bg-stone-900 rounded-[200px] flex items-center justify-center overflow-hidden"
          >
            <button
              type="submit"
              class="group inline-flex items-center justify-center gap-2 w-full h-full text-lg font-light text-[#ffeead] sm:text-xl hover:bg-white/5 transition-colors"
            >
              Submit
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>
</section>

<style>
  .contact-input {
    border-radius: 0.75rem;
    border: 1.5px dashed #050505;
    background: transparent;
    padding: 0.6rem 0.8rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: #050505;
    outline: none;
    transition: border 0.2s ease;
    width: 100%;
  }

  .contact-input:focus {
    border-color: #f95f4a;
  }

  /* Adjust form layout for the laptop screen size */
  .contact-form {
    height: auto;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { getAssetUrl } from "../utils/cdn";

  gsap.registerPlugin(ScrollTrigger);

  const canvas = document.querySelector("#laptop-canvas") as HTMLCanvasElement;
  const context = canvas.getContext("2d");

  // Set canvas dimensions to match the image aspect ratio or window
  // For now, let's set a base resolution and scale it with CSS
  canvas.width = 1920;
  canvas.height = 1080;

  const frameCount = 125;
  const currentFrame = (index: number) =>
    getAssetUrl(
      `/outputFolder/frame_${(index + 1).toString().padStart(4, "0")}.png`
    );

  const images: HTMLImageElement[] = [];
  const laptop = {
    frame: 0,
  };

  // Preload images
  for (let i = 0; i < frameCount; i++) {
    const img = new Image();
    img.src = currentFrame(i);
    images.push(img);
  }

  // Ensure the first image is loaded before rendering
  images[0].onload = render;

  const tl = gsap.timeline({
    scrollTrigger: {
      trigger: ".laptop-section",
      start: "top top",
      end: "bottom bottom",
      scrub: 0.5,
    },
  });

  // Add a delay at the start (hold frame 0 for a portion of the scroll)
  tl.to(laptop, {
    frame: 0,
    duration: 0.5, // Adjust this value to control the delay length relative to total scroll
    onUpdate: render,
  })
    .to(laptop, {
      frame: frameCount - 1,
      snap: "frame",
      ease: "none",
      duration: 2, // The animation takes up the rest of the scroll
      onUpdate: render,
    })
    .to(
      ".contact-heading",
      {
        opacity: 0,
        y: -50, // Fade up
        duration: (20 / frameCount) * 2, // Fade out over 20 frames (40 to 60)
        ease: "none",
      },
      `<+${(40 / frameCount) * 2}`
    ) // Start at frame 40
    .to(
      ".contact-form-overlay",
      {
        opacity: 1,
        pointerEvents: "auto",
        duration: 0.5,
        ease: "power2.inOut",
      },
      `<+${(40 / frameCount) * 2}`
    ); // Start at frame 80 (40 + 40)

  function render() {
    if (context && images[laptop.frame]) {
      context.clearRect(0, 0, canvas.width, canvas.height);

      // Draw image to cover/contain within canvas
      context.drawImage(
        images[laptop.frame],
        0,
        0,
        canvas.width,
        canvas.height
      );
    }
  }

  // Handle resize if needed, though CSS object-contain handles display size

  // Form handling
  const form = document.getElementById(
    "contact-form-desktop"
  ) as HTMLFormElement;
  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]');
      const originalBtnText = submitBtn ? submitBtn.innerHTML : "Submit";

      if (submitBtn) {
        submitBtn.innerHTML = "Sending...";
        (submitBtn as HTMLButtonElement).disabled = true;
      }

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      try {
        const response = await fetch("/api/contact", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(data),
        });

        if (response.ok) {
          alert("Message sent successfully!");
          form.reset();
        } else {
          const resData = await response.json();
          alert(
            `Failed to send message: ${resData.message || "Unknown error"}`
          );
        }
      } catch (error) {
        console.error("Error:", error);
        alert("An error occurred. Please try again later.");
      } finally {
        if (submitBtn) {
          submitBtn.innerHTML = originalBtnText;
          (submitBtn as HTMLButtonElement).disabled = false;
        }
      }
    });
  }
</script>
