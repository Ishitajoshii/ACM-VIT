---

---

<section class="domains-section relative h-[300vh] motion-reduce:h-screen">
  <!-- Fixed Background Layer -->
  <div class="fixed inset-0 z-0 pointer-events-none opacity-0 domain-bg-layer">
    <img
      src="/glow_ball_red.svg"
      alt=""
      class="w-full h-full object-cover scale-125"
    />
  </div>

  <div
    class="pin-container sticky top-0 flex h-screen items-center justify-center overflow-visible will-change-transform transform-gpu motion-reduce:static z-10"
  >
    <p
      class="section-subtitle absolute top-[10%] pt-2 md:pt-4 md:top-[12%] left-1/2 z-10 max-w-[95%] md:max-w-[900px] -translate-x-1/2 px-6 md:px-8 text-center font-['PolySans_Trial',sans-serif] text-[4px] md:text-[18px] font-normal leading-[1.6] md:leading-[1.4] text-[#fefcd9] will-change-[transform,opacity] [transform-style:preserve-3d] backface-hidden"
    >
      <span class="whitespace-nowrap">
        Each domain at ACM-VIT is more than a skillset, it's a mindset.
      </span><br class="hidden md:inline" />
      <span class="whitespace-nowrap">
        We build, break, design, analyze, and communicate, not in silos, but in
        sync.
      </span><br class="hidden md:inline" />
      <span class="whitespace-nowrap">
        Because true innovation happens where disciplines intersect.
      </span><br class="hidden md:inline" />
    </p>

    <div
      class="domains-grid relative flex h-screen w-screen items-center justify-center overflow-visible p-5 origin-center will-change-transform [transform-style:preserve-3d] backface-hidden"
    >
      <div
        class="domain-item absolute left-1/2 top-1/2 m-2.5 p-2.5 -translate-x-1/2 -translate-y-1/2 will-change-[transform,opacity] [transform-style:preserve-3d] backface-hidden [contain:layout_style_paint]"
        data-domain="tech"
      >
        <div class="cassette-wrapper">
          <img
            src="/Cassette_Tech.svg"
            alt="Tech Development"
            class="cassette-img block h-auto w-[160px] md:w-[300px] origin-center transform-gpu drop-shadow-[0_2px_4px_rgba(0,0,0,0.2)] will-change-transform [image-rendering:optimizeQuality] backface-hidden"
          />
        </div>
      </div>
      <div
        class="domain-item absolute left-1/2 top-1/2 m-2.5 p-2.5 -translate-x-1/2 -translate-y-1/2 will-change-[transform,opacity] [transform-style:preserve-3d] backface-hidden [contain:layout_style_paint]"
        data-domain="cc"
      >
        <div class="cassette-wrapper">
          <img
            src="/Cassette_cc.svg"
            alt="Competitive Coding"
            class="cassette-img block h-auto w-[160px] md:w-[300px] origin-center transform-gpu drop-shadow-[0_2px_4px_rgba(0,0,0,0.2)] will-change-transform [image-rendering:optimizeQuality] backface-hidden"
          />
        </div>
      </div>
      <div
        class="domain-item absolute left-1/2 top-1/2 m-2.5 p-2.5 -translate-x-1/2 -translate-y-1/2 will-change-[transform,opacity] [transform-style:preserve-3d] backface-hidden [contain:layout_style_paint]"
        data-domain="design"
      >
        <div class="cassette-wrapper">
          <img
            src="/Cassette_Design.svg"
            alt="Design"
            class="cassette-img block h-auto w-[160px] md:w-[300px] origin-center transform-gpu drop-shadow-[0_2px_4px_rgba(0,0,0,0.2)] will-change-transform [image-rendering:optimizeQuality] backface-hidden"
          />
        </div>
      </div>
      <div
        class="domain-item absolute left-1/2 top-1/2 m-2.5 p-2.5 -translate-x-1/2 -translate-y-1/2 will-change-[transform,opacity] [transform-style:preserve-3d] backface-hidden [contain:layout_style_paint]"
        data-domain="management"
      >
        <div class="cassette-wrapper">
          <img
            src="/Cassette_Management.svg"
            alt="Management"
            class="cassette-img block h-auto w-[160px] md:w-[300px] origin-center transform-gpu drop-shadow-[0_2px_4px_rgba(0,0,0,0.2)] will-change-transform [image-rendering:optimizeQuality] backface-hidden"
          />
        </div>
      </div>
      <div
        class="domain-item absolute left-1/2 top-1/2 m-2.5 p-2.5 -translate-x-1/2 -translate-y-1/2 will-change-[transform,opacity] [transform-style:preserve-3d] backface-hidden [contain:layout_style_paint]"
        data-domain="research"
      >
        <div class="cassette-wrapper">
          <img
            src="/Cassette_Research.svg"
            alt="Research"
            class="cassette-img block h-auto w-[160px] md:w-[300px] origin-center transform-gpu drop-shadow-[0_2px_4px_rgba(0,0,0,0.2)] will-change-transform [image-rendering:optimizeQuality] backface-hidden"
          />
        </div>
      </div>
    </div>
    <style>
      .cassette-wrapper {
        position: relative;
        padding: 2px;
        border-radius: 12px;
        background: transparent;
        overflow: hidden;
        /* box-shadow removed as per request */
      }

      .cassette-wrapper::before {
        content: "";
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: conic-gradient(
          transparent,
          transparent,
          transparent,
          transparent,
          #fefcd9
        );
        animation: rotate 3s linear infinite;
        z-index: 0;
      }

      .cassette-wrapper::after {
        content: "";
        position: absolute;
        inset: 2px;
        background: #050505;
        border-radius: 10px;
        z-index: 0;
      }

      .cassette-img {
        position: relative;
        z-index: 1;
        border-radius: 10px;
      }

      @keyframes rotate {
        0% {
          transform: rotate(0deg);
        }
        100% {
          transform: rotate(360deg);
        }
      }
    </style>

    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import { domainConfigs } from "../data/domainsData";

      if (typeof gsap !== "undefined") {
        gsap.registerPlugin(ScrollTrigger);

        // Optimized GSAP config
        gsap.config({
          force3D: true,
          nullTargetWarn: false,
        });

        // Debounced initialization
        let initialized = false;

        function initAnimation() {
          if (initialized) return;
          initialized = true;

          // Grid positions (2x3 layout)
          const gridPos = [
            { x: -500, y: -70 }, // Tech
            { x: 0, y: -70 }, // CC
            { x: 500, y: -70 }, // Design
            { x: -300, y: 200 }, // Management
            { x: 300, y: 200 }, // Research
          ];

          // Horizontal line positions
          const linePos = [
            { x: -480, y: 0 }, // Tech
            { x: -240, y: 0 }, // CC
            { x: 0, y: 0 }, // Design
            { x: 240, y: 0 }, // Management
            { x: 480, y: 0 }, // Research
          ];

          // Zoom positions
          const zoomPos = [
            { x: -800, y: 0 }, // Tech : move left
            { x: -480, y: 0 }, // CC : move left
            { x: -240, y: 0 }, // Design : move left
            { x: 240, y: 0 }, // Management : move right
            { x: 480, y: 0 }, // Research : move right
          ];

          const items = document.querySelectorAll(".domain-item");
          const grid = document.querySelector(".domains-grid");
          const subtitle = document.querySelector(".section-subtitle");
          const bgLayer = document.querySelector(".domain-bg-layer");

          if (!items.length || !grid || !subtitle || !bgLayer) return;

          // Set initial state
          gsap.set(items, {
            x: 0,
            y: 0,
            scale: 0.6,
            opacity: 0,
            force3D: true,
          });

          // initial state for subtitle (text)
          gsap.set(subtitle, {
            opacity: 0,
            y: 20,
            scale: 0.9,
            force3D: true,
          });

          const tl = gsap.timeline({
            scrollTrigger: {
              trigger: ".domains-section",
              start: "-300px top",
              end: "bottom bottom",
              scrub: 1.2,
              pin: "true",
              anticipatePin: 1,
              invalidateOnRefresh: true,
              markers: false,
              onEnter: () =>
                gsap.to(bgLayer, { opacity: 1, duration: 0.5, delay: 0.5 }),
              onLeave: () =>
                gsap.to(bgLayer, { opacity: 0, duration: 0.5, delay: 0.5 }), // Fade out with delay
              onEnterBack: () =>
                gsap.to(bgLayer, { opacity: 1, duration: 0.5 }),
              onLeaveBack: () =>
                gsap.to(bgLayer, { opacity: 0, duration: 0.5 }),
            },
          });

          // Phase 1: Appear and form grid
          tl.to(subtitle, {
            opacity: 1,
            y: 0,
            scale: 1,
            duration: 2,
            ease: "power2.out",
          })
            .to(
              items,
              {
                opacity: 1,
                scale: 1,
                duration: 2,
                ease: "power2.out",
                stagger: 0.1,
              },
              "<+=0.2"
            )
            .to(
              items,
              {
                x: (i) => gridPos[i].x,
                y: (i) => gridPos[i].y,
                duration: 3,
                ease: "power2.inOut",
              },
              "-=1"
            );

          // Phase 2: Form horizontal line
          tl.to(items, {
            x: (i) => linePos[i].x,
            y: (i) => linePos[i].y,
            scale: 0.7,
            duration: 3,
            ease: "power1.inOut",
          }).to(
            subtitle,
            {
              opacity: 0,
              y: -30,
              duration: 2,
              ease: "power2.out",
            },
            "<"
          );

          // Phase 3: Simplified zoom effect
          tl.to(grid, {
            scale: 10,
            duration: 5,
            ease: "power1.inOut",
          }).to(
            items,
            {
              x: (i) => zoomPos[i].x,
              y: (i) => zoomPos[i].y,
              opacity: 100,
              scale: 0.5,
              duration: 2,
              ease: "power2.in",
              stagger: 0.0,
            },
            "<+=0.5"
          );

          // Simplified hover effects
          items.forEach((item, index) => {
            const img = item.querySelector(".cassette-img");
            if (!img) return;

            let hoverTween: gsap.core.Tween | null = null;

            item.addEventListener("mouseenter", () => {
              if (hoverTween) hoverTween.kill();
              hoverTween = gsap.to(img, {
                scale: 1.03,
                duration: 0.2,
                ease: "power2.out",
                transformOrigin: "center center",
              });
            });

            item.addEventListener("mouseleave", () => {
              if (hoverTween) hoverTween.kill();
              hoverTween = gsap.to(img, {
                scale: 1,
                duration: 0.2,
                ease: "power2.out",
                transformOrigin: "center center",
              });
            });

            // Add click event handler for domain screen
            item.addEventListener("click", () => {
              const domain = item.getAttribute("data-domain");
              if (domain) {
                showDomainScreen(domain);
              }
            });
          });
        }

        // Function to show domain screen
        function showDomainScreen(domain: string) {
          // Hide all cassettes and subtitle with animation
          const items = document.querySelectorAll(".domain-item");
          const subtitle = document.querySelector(".section-subtitle");
          const bgLayer = document.querySelector(".domain-bg-layer");

          // Create a smooth transition timeline
          const tl = gsap.timeline();

          // Fade out background and elements simultaneously
          if (bgLayer) {
            tl.to(
              bgLayer,
              {
                opacity: 0,
                duration: 0.4,
                ease: "power2.inOut",
              },
              0
            );
          }

          tl.to(
            items,
            {
              opacity: 0,
              scale: 0.8,
              duration: 0.4,
              ease: "power2.inOut",
              stagger: 0.02,
            },
            0
          ).to(
            subtitle,
            {
              opacity: 0,
              y: -30,
              duration: 0.3,
              ease: "power2.inOut",
            },
            0.05
          );

          setTimeout(() => {
            createDomainScreen(domain);
            // Hide header
            const header = document.querySelector("header");
            if (header) {
              gsap.to(header, {
                y: -100,
                opacity: 0,
                duration: 0.3,
                ease: "power2.inOut",
              });
            }
          }, 200);
        }

        // Function to create domain screen component
        function createDomainScreen(domain: string) {
          // Import domain configs from external file
          const config = domainConfigs[domain as keyof typeof domainConfigs];
          if (!config) return;

          // Create domain screen HTML using DomainProjectScreen component structure
          const domainScreenHTML = createDomainScreenContent(config);

          // Insert the domain screen
          const domainScreenDiv = document.createElement("div");
          domainScreenDiv.id = "domain-screen";
          domainScreenDiv.className = "fixed inset-0 z-50 overflow-y-auto";
          domainScreenDiv.style.scrollbarWidth = "none"; // Firefox
          (domainScreenDiv.style as any).msOverflowStyle = "none"; // IE/Edge
          domainScreenDiv.innerHTML = domainScreenHTML;

          // Add webkit scrollbar hiding
          const style = document.createElement("style");
          style.textContent = `
                #domain-screen::-webkit-scrollbar {
                    display: none;
                }
            `;
          document.head.appendChild(style);

          document.body.appendChild(domainScreenDiv);

          // Smooth entrance animation with better timing
          gsap.fromTo(
            domainScreenDiv,
            {
              opacity: 0,
              y: 30,
              scale: 0.95,
            },
            {
              opacity: 1,
              y: 0,
              scale: 1,
              duration: 0.4,
              ease: "power2.out",
              delay: 0.1,
            }
          );
        }

        // Function to create domain screen content
        function createDomainScreenContent(config: any) {
          // Simple theme colors
          const themeColors = {
            tech: "#9B51E0",
            cc: "#B4E35B",
            design: "#FF7777",
            research: "#9AF3FF",
            management: "#008080",
            competitive: "#42CD9D",
          };

          const themeHex =
            themeColors[config.themeColor as keyof typeof themeColors] ||
            themeColors.tech;

          return `
                <div class="min-h-screen text-white">
                    <!-- Back Button -->
                    <div class="fixed top-6 right-6 z-50">
                        <button 
                            onclick="hideDomainScreen()"
                            class="relative w-12 h-12 flex items-center justify-center hover:opacity-80 transition-opacity"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" width="50" height="50" viewBox="0 0 50 50" fill="none" class="absolute">
                                <circle cx="25" cy="25" r="24.5" stroke="#FEFCD9"/>
                            </svg>
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="relative z-10">
                                <path d="M3 19V5" stroke="#FEFCD9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M13 6L7 12L13 18" stroke="#FEFCD9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M7 12H21" stroke="#FEFCD9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </button>
                    </div>

                    <!-- Hero Section with Theme Header -->
                    <div class="pt-20 pb-8 px-8">
                        <!-- Main Title Card -->
                        <div class="mx-auto max-w-6xl mb-8 relative">
                            <!-- SVG Background -->
                            <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="178" viewBox="0 0 1389 178" fill="none" class="w-full">
                                <path d="M88 1.5H1301C1348.77 1.5 1387.5 40.2274 1387.5 88V90C1387.5 137.773 1348.77 176.5 1301 176.5H88C40.2274 176.5 1.5 137.773 1.5 90V88C1.5 40.2274 40.2274 1.5 88 1.5Z" fill="${themeHex}" stroke="#FEFCD9" stroke-width="3"/>
                            </svg>
                            
                            <!-- Content overlay -->
                            <div class="absolute inset-0 flex items-center justify-center p-8">
                                <!-- Decorative Elements -->
                                <div class="absolute left-8 top-1/2 -translate-y-1/2">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 124 124" fill="none" class="animate-spin" style="animation-duration: 8s;">
                                        <circle cx="62" cy="62" r="57.5" stroke="#1E1E1E" stroke-width="3"/>
                                        <path d="M61.6582 18C67.7102 18 73.4766 19.2231 78.7246 21.4336L73.4238 30.6182L82.9629 36.126L88.2588 26.9512C97.4504 33.9379 103.81 44.4557 105.314 56.4844H94.7051V67.5H105.316C103.815 79.5413 97.4473 90.0689 88.2441 97.0586L82.9473 87.8828L73.4082 93.3906L78.709 102.572C73.4651 104.779 67.7043 106 61.6582 106C55.6035 106 49.8348 104.776 44.585 102.563L49.8945 93.3672L40.3555 87.8594L35.0527 97.0439C25.8603 90.0541 19.5005 79.5326 18 67.5H28.6123V56.4844H18.002C19.5071 44.4491 25.8735 33.9262 35.0732 26.9395L40.3721 36.1172L49.9121 30.6104L44.6094 21.4258C49.8527 19.2199 55.6129 18.0001 61.6582 18Z" fill="#1E1E1E"/>
                                    </svg>
                                </div>
                                
                                <div class="absolute right-8 top-1/2 -translate-y-1/2">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 124 124" fill="none" class="animate-spin" style="animation-duration: 8s;">
                                        <circle cx="62" cy="62" r="57.5" stroke="#1E1E1E" stroke-width="3"/>
                                        <path d="M61.6582 18C67.7102 18 73.4766 19.2231 78.7246 21.4336L73.4238 30.6182L82.9629 36.126L88.2588 26.9512C97.4504 33.9379 103.81 44.4557 105.314 56.4844H94.7051V67.5H105.316C103.815 79.5413 97.4473 90.0689 88.2441 97.0586L82.9473 87.8828L73.4082 93.3906L78.709 102.572C73.4651 104.779 67.7043 106 61.6582 106C55.6035 106 49.8348 104.776 44.585 102.563L49.8945 93.3672L40.3555 87.8594L35.0527 97.0439C25.8603 90.0541 19.5005 79.5326 18 67.5H28.6123V56.4844H18.002C19.5071 44.4491 25.8735 33.9262 35.0732 26.9395L40.3721 36.1172L49.9121 30.6104L44.6094 21.4258C49.8527 19.2199 55.6129 18.0001 61.6582 18Z" fill="#1E1E1E"/>
                                    </svg>
                                </div>

                                <!-- Domain Title -->
                                <div class="text-center">
                                    <h1 class="${config.title === "COMPETITIVE CODING" ? "text-4xl md:text-6xl" : "text-6xl md:text-8xl"} font-normal text-[#1E1E1E] tracking-wider">
                                        ${config.title}
                                    </h1>
                                </div>
                            </div>
                        </div>

                        <!-- Tech Stack Icons -->
                        ${
                          config.techIcons.length > 0
                            ? `
                            <div class="flex justify-center items-center gap-8 mb-12 flex-wrap px-8">
                                ${config.techIcons
                                  .map(
                                    (icon: any) => `
                                    <div class="flex items-center justify-center hover:scale-110 transition-transform duration-300">
                                        <img 
                                            src="${icon.src}" 
                                            alt="${icon.alt}" 
                                            class="w-12 h-12 md:w-12 md:h-12 grayscale hover:grayscale-0 transition-all duration-300 opacity-70 hover:opacity-100" 
                                        />
                                    </div>
                                `
                                  )
                                  .join("")}
                            </div>
                        `
                            : ""
                        }

                        <!-- Description -->
                        <div class="max-w-4xl mx-auto text-center mb-12">
                            <p class="text-[#FEFCD9] text-lg leading-relaxed">
                                ${config.description}
                            </p>
                        </div>

                        <!-- Projects Button -->
                        <div class="flex justify-center mb-12">
                            <button 
                                class="flex justify-center items-center px-6 py-3 h-[50px] rounded-[41px] border border-[#FEFCD9] font-medium hover:shadow-lg transition-shadow whitespace-nowrap ${config.themeColor === "competitive" || config.themeColor === "research" || config.themeColor === "tech" ? "text-black" : "text-white"}"
                                style="background-color: ${themeHex}"
                            >
                                ${config.buttonText}
                            </button>
                        </div>

                        <!-- AOIs or Cassettes -->
                        ${
                          config.aois && config.aois.length > 0
                            ? `
                            <div class="flex justify-center items-center gap-8 mb-12 flex-wrap px-8">
                                ${config.aois
                                  .map(
                                    (aoi: any) => `
                                    <div class="flex flex-col items-center justify-center gap-2 hover:scale-105 transition-transform duration-300">
                                        <img 
                                            src="${aoi.src}" 
                                            alt="${aoi.alt}" 
                                            class="w-32 h-32 md:w-48 md:h-48 object-contain" 
                                        />
                                        <span class="text-[#FEFCD9] text-sm md:text-base font-medium tracking-wide">${aoi.alt}</span>
                                    </div>
                                `
                                  )
                                  .join("")}
                            </div>
                        `
                            : ""
                        }
                    </div>
                </div>
            `;
        }

        // Global function to hide domain screen
        (window as any).hideDomainScreen = function () {
          const domainScreen = document.getElementById("domain-screen");
          const items = document.querySelectorAll(".domain-item");
          const subtitle = document.querySelector(".section-subtitle");
          const bgLayer = document.querySelector(".domain-bg-layer");

          if (domainScreen) {
            // Create smooth exit timeline
            const exitTl = gsap.timeline({
              onComplete: () => {
                domainScreen.remove();

                // Create smooth entrance timeline for original elements
                const entranceTl = gsap.timeline();

                // Restore the glow ball background first
                if (bgLayer) {
                  entranceTl.to(
                    bgLayer,
                    {
                      opacity: 1,
                      duration: 0.3,
                      ease: "power2.out",
                    },
                    0
                  );
                }

                // Then bring back cassettes and subtitle with stagger
                entranceTl
                  .to(
                    items,
                    {
                      opacity: 1,
                      scale: 1,
                      duration: 0.4,
                      ease: "power2.out",
                      stagger: 0.04,
                    },
                    0.1
                  )
                  .to(
                    subtitle,
                    {
                      opacity: 1,
                      y: 0,
                      duration: 0.3,
                      ease: "power2.out",
                    },
                    0.15
                  );
              },
            });

            // Smooth exit animation
            exitTl.to(domainScreen, {
              opacity: 0,
              y: -20,
              scale: 0.98,
              duration: 0.3,
              ease: "power2.inOut",
              onStart: () => {
                // Restore header
                const header = document.querySelector("header");
                if (header) {
                  gsap.to(header, {
                    y: 0,
                    opacity: 1,
                    duration: 0.3,
                    ease: "power2.out",
                  });
                }
              },
            });
          }
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", initAnimation);
        } else {
          initAnimation();
        }
      }
    </script>
  </div>
</section>
