---
    <style>
        .domains-section {
            height: 300vh;
            background: url('/glow_ball_red.svg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            position: relative;
            /* Optimize for performance */
            contain: layout style paint;
        }

        .pin-container {
            position: sticky;
            top: 0;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: visible;
            /* Optimize rendering */
            will-change: transform;
            transform: translateZ(0);
        }

        .section-subtitle {
            color: #fefcd9;
            text-align: center;
            font-family: 'PolySans Trial', sans-serif;
            font-size: 20.667px;
            font-weight: 400;
            max-width: 800px;
            position: absolute;
            top: 10%;
            left: 50%;
            transform: translateX(-50%);
            z-index: 10;
            /* Performance optimization */
            will-change: transform, opacity;
            transform-style: preserve-3d;
            backface-visibility: hidden;
        }

        .domains-grid {
            position: relative;
            width: 100vw;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            transform-origin: center center;
            /* GPU acceleration */
            will-change: transform;
            transform-style: preserve-3d;
            backface-visibility: hidden;
            overflow: visible;
            padding: 20px; 
        }

        .domain-item {
            position: absolute;
            left: 50%;
            top: 50%;
            transform: translate(-50%, -50%);
            /* Optimized GPU acceleration */
            will-change: transform, opacity;
            transform-style: preserve-3d;
            backface-visibility: hidden;
            contain: layout style paint;
            padding: 10px;
            margin: 10px;
        }

        .cassette-img {
            width: 300px;
            height: auto;
            display: block;
            filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.2));
            /* Optimized GPU acceleration */
            transform: translateZ(0);
            will-change: transform;
            /* Better image rendering */
            image-rendering: optimizeQuality;
            -webkit-backface-visibility: hidden;
            backface-visibility: hidden;
            transform-origin: center center;
        }

        @media (max-width: 768px) {
            .cassette-img {
                width: 160px;
            }
            .section-subtitle {
                font-size: 16px;
                padding: 0 1.5rem;
                top: 12%;
            }
            .domains-section {
                background-attachment: scroll; /* Better mobile performance */
            }
        }

        /* Performance optimizations */
        @media (prefers-reduced-motion: reduce) {
            .domains-section {
                height: 100vh;
            }
            .pin-container {
                position: static;
            }
        }
    </style>


<section class="domains-section">
    <div class="pin-container">
            <p class="section-subtitle">
                <span style="display:block;">
                    Each domain at ACM-VIT is more than a skillset — it's a mindset.
                </span>
                <span style="display:block;">
                    We build, break, design, analyze, and communicate — not in silos, but in sync.
                </span>
                <span style="display:block;">
                    Because true innovation happens where disciplines intersect.
                </span>
            </p>

        <div class="domains-grid">
            <div class="domain-item" data-domain="app">
                <img src="/Cassette_App.svg" alt="App Development" class="cassette-img" />
            </div>
            <div class="domain-item" data-domain="cc">
                <img src="/Cassette_cc.svg" alt="Competitive Coding" class="cassette-img" />
            </div>
            <div class="domain-item" data-domain="design">
                <img src="/Cassette_Design.svg" alt="Design" class="cassette-img" />
            </div>
            <div class="domain-item" data-domain="management">
                <img src="/Cassette_Management.svg" alt="Management" class="cassette-img" />
            </div>
            <div class="domain-item" data-domain="research">
                <img src="/Cassette_Research.svg" alt="Research" class="cassette-img" />
            </div>
            <div class="domain-item" data-domain="web">
                <img src="/Cassette_Web.svg" alt="Web Development" class="cassette-img" />
            </div>
        </div>
    </div>
</section>


<script>
    import  {gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    if (typeof gsap !== 'undefined') {
        gsap.registerPlugin(ScrollTrigger);

        // Optimized GSAP config
        gsap.config({
            force3D: true,
            nullTargetWarn: false
        });

        // Debounced initialization
        let initialized = false;
        
        function initAnimation() {
            if (initialized) return;
            initialized = true;

            // Grid positions (2x3 layout)
            const gridPos = [
                { x: -500, y: -70 }, // App
                { x: 0, y: -70 },    // CC
                { x: 500, y: -70 },  // Design
                { x: -500, y: 200 },  // Management  
                { x: 0, y: 200 },     // Research
                { x: 500, y: 200 }    // Web
            ];

            // Horizontal line positions
            const linePos = [
                { x: -600, y: 0 },   // App
                { x: 120, y: 0 },   // CC
                { x: 360, y: 0 },    // Design
                { x: -360, y: 0 },    // Management
                { x: -120, y: 0 },   // Research
                { x: 600, y: 0 }     // Web
            ];

            // Zoom positions
            const zoomPos = [
                { x: -800, y: 0 },   // App : move left
                { x: 240, y: 0 },   // CC : move right
                { x: 480, y: 0 },    // Design : move right
                { x: -480, y: 0 },    // Management : move left
                { x: -240, y: 0 },   // Research : move left
                { x: 480, y: 0 }     // Web : move right
            ];

            const items = document.querySelectorAll('.domain-item');
            const grid = document.querySelector('.domains-grid');
            const subtitle = document.querySelector('.section-subtitle');

            if (!items.length || !grid || !subtitle) return;

            // Set initial state
            gsap.set(items, {
                x: 0,
                y: 0,
                scale: 0.6,
                opacity: 0,
                force3D: true
            });

            // initial state for subtitle (text)
            gsap.set(subtitle, {
                opacity: 0,
                y: 20,
                scale: 0.9,
                force3D: true
            });

            // Simplified timeline with better performance
            const tl = gsap.timeline({
                scrollTrigger: {
                    trigger: '.domains-section',
                    start: '-580px top',
                    end: 'bottom bottom',
                    scrub: 1.2,
                    pin: 'true',
                    anticipatePin: 1,
                    invalidateOnRefresh: true,
                    markers: false,
                }
            });

            // Phase 1: Appear and form grid
            tl.to(subtitle, {
                opacity: 1,
                y: 0,
                scale: 1,
                duration: 2,
                ease: "power2.out"
            })
            .to(items, {
                opacity: 1,
                scale: 1,
                duration: 2,
                ease: "power2.out",
                stagger: 0.1
            }, "<+=0.2")
            .to(items, {
                x: (i) => gridPos[i].x,
                y: (i) => gridPos[i].y,
                duration: 3,
                ease: "power2.inOut"
            }, "-=1");

            // Phase 2: Form horizontal line
            tl.to(items, {
                x: (i) => linePos[i].x,
                y: (i) => linePos[i].y,
                scale: 0.7,
                duration: 3,
                ease: "power1.inOut"
            })
            .to(subtitle, {
                opacity: 0,
                y: -30,
                duration: 2,
                ease: "power2.out"
            }, "<");

            // Phase 3: Simplified zoom effect
            tl.to(grid, {
                scale: 10,
                duration: 5,
                ease: "power1.inOut"
            })
            .to(items, {
                x: (i) => zoomPos[i].x,
                y: (i) => zoomPos[i].y,
                opacity: 100,
                scale: 0.5,
                duration: 2,
                ease: "power2.in",
                stagger: 0.00
            }, "<+=0.5")

            // Simplified hover effects
            items.forEach((item, index) => {
                const img = item.querySelector('.cassette-img');
                if (!img) return;
                
                let hoverTween: gsap.core.Tween | null = null;
                
                item.addEventListener('mouseenter', () => {
                    if (hoverTween) hoverTween.kill();
                    hoverTween = gsap.to(img, {
                        scale: 1.03,
                        duration: 0.2,
                        ease: "power2.out",
                        transformOrigin: "center center"
                    });
                });
                
                item.addEventListener('mouseleave', () => {
                    if (hoverTween) hoverTween.kill();
                    hoverTween = gsap.to(img, {
                        scale: 1,
                        duration: 0.2,
                        ease: "power2.out",
                        transformOrigin: "center center"
                    });
                });

                // Add click event handler for domain screen
                item.addEventListener('click', () => {
                    const domain = item.getAttribute('data-domain');
                    if (domain) {
                        showDomainScreen(domain);
                    }
                });
            });
        }

        // Function to show domain screen
        function showDomainScreen(domain: string) {
            // Hide all cassettes and subtitle with animation
            const items = document.querySelectorAll('.domain-item');
            const subtitle = document.querySelector('.section-subtitle');
            const domainsSection = document.querySelector('.domains-section');
            
            // Create a smooth transition timeline
            const tl = gsap.timeline();
            
            // Fade out background and elements simultaneously
            tl.to(domainsSection, {
                backgroundSize: '0% 0%',
                opacity: 0,
                duration: 0.4,
                ease: "power2.inOut"
            }, 0)
            .to(items, {
                opacity: 0,
                scale: 0.8,
                duration: 0.4,
                ease: "power2.inOut",
                stagger: 0.02
            }, 0)
            .to(subtitle, {
                opacity: 0,
                y: -30,
                duration: 0.3,
                ease: "power2.inOut"
            }, 0.05);

            // Create and show domain screen after animation with overlap
            setTimeout(() => {
                createDomainScreen(domain);
            }, 200);
        }

        // Function to create domain screen component
        function createDomainScreen(domain: string) {
            // Domain configurations matching your manual setup
            const domainConfigs = {
                app: {
                    title: "APP",
                    description: "We build tools that people actually use in a world driven by digital experiences. From frontend finesse to backend logic, we focus on developing full-stack applications that solve real problems. We collaborate on real-world projects, explore the latest technologies, and grow as developers through hands-on experience. It's where curiosity turns into code and ideas turn into seamless digital experiences.",
                    themeColor: "app",
                    cassetteSvg: "/Cassette_App.svg",
                    techIcons: [
                        { src: "/domains/app/android.svg", alt: "Android" },
                        { src: "/domains/app/dart.svg", alt: "Dart" },
                        { src: "/domains/app/flutter.svg", alt: "Flutter" },
                        { src: "/domains/app/java.svg", alt: "Java" },
                        { src: "/domains/app/kotlin.svg", alt: "Kotlin" },
                        { src: "/domains/app/reactjs.svg", alt: "React Native" },
                        { src: "/domains/app/swift.svg", alt: "Swift" },
                        { src: "/domains/app/typescript.svg", alt: "TypeScript" }
                    ]
                },
                cc: {
                    title: "COMPETITIVE CODING",
                    description: "We see competitive programming as a game of logic, strategy, and precision, far beyond just writing code. We host contests, craft cryptic challenges, and build problem sets that push us to think algorithmically. Whether we're solving our first problem or chasing the next rating jump, we do it together - discussing, debating, and decoding as a team. In this space, sharpening skills becomes second nature and way more fun. Every problem we solve makes us a little sharper and a lot more confident.",
                    themeColor: "competitive",
                    cassetteSvg: "/Cassette_cc.svg",
                    techIcons: [
                        { src: "/domains/cc/codeforces_icon 1.svg", alt: "Codeforces" },
                        { src: "/domains/cc/c++.svg", alt: "C++" },
                        { src: "/domains/cc/ICPC_Foundation_logo 1.svg", alt: "ICPC" },
                        { src: "/domains/cc/vim.svg", alt: "Vim" }
                    ]
                },
                design: {
                    title: "DESIGN",
                    description: "We craft visual experiences that bring our ideas and events to life - from UI/UX design and motion graphics to social media posts and video edits. With a focus on aesthetics, usability, and storytelling, we shape how the world sees ACM. Whether it's building brand identity or designing user-first interfaces, we blend art with purpose to create meaningful designs. Every pixel, frame, and layout is intentional, because great design isn't just seen, it's felt.",
                    themeColor: "design",
                    cassetteSvg: "/Cassette_Design.svg",
                    techIcons: [
                        { src: "/domains/design/ae.svg", alt: "AE" },
                        { src: "/domains/design/ai.svg", alt: "AI" },
                        { src: "/domains/design/figma.svg", alt: "Figma" },
                        { src: "/domains/design/final-cut-pro-new 1.svg", alt: "FinalCut" },
                        { src: "/domains/design/ps.svg", alt: "PS" },
                        { src: "/domains/design/blender.svg", alt: "Blender" }
                    ]
                },
                web: {
                    title: "WEB",
                    description: "We create digital experiences that combine purpose with performance, ensuring every interaction feels seamless and intentional. From dynamic frontends to robust backend systems, everything we build is smooth, efficient, and reliable. We prioritize accessibility, performance, and scalability, working together to turn ideas into impactful solutions. It's not just about building websites, it's about creating systems that deliver consistent and meaningful user experiences.",
                    themeColor: "web",
                    cassetteSvg: "/Cassette_Web.svg",
                    techIcons: [
                        { src: "/domains/web/cloudflare.svg", alt: "Cloudflare" },
                        { src: "/domains/web/cockroachdb 1.svg", alt: "CockroachDB" },
                        { src: "/domains/web/docker.svg", alt: "Docker" },
                        { src: "/domains/web/go-gopher-svgrepo-com 1.svg", alt: "Go" },
                        { src: "/domains/web/Group.svg", alt: "Group" },
                        { src: "/domains/web/nextjs2.svg", alt: "Next.js" },
                        { src: "/domains/web/nodejs.svg", alt: "Node.js" },
                        { src: "/domains/web/npm2.svg", alt: "npm" },
                        { src: "/domains/web/postgresql.svg", alt: "PostgreSQL" },
                        { src: "/domains/web/postman.svg", alt: "Postman" },
                        { src: "/domains/web/prisma.svg", alt: "Prisma" },
                        { src: "/domains/web/redis.svg", alt: "Redis" },    
                        { src: "/domains/web/tailwindcss.svg", alt: "TailwindCSS" },
                        { src: "/domains/web/typescript.svg", alt: "TypeScript" }
                    ]
                },
                research: {
                    title: "RESEARCH",
                    description: "Curiosity, collaboration, and a passion for exploration drive everything we do. We explore cutting-edge technologies, work across disciplines, and drive innovation through hands-on mentorship and real-world problem solving. From crafting thought-provoking challenges for our flagship events to publishing insightful blogs, we turn questions into breakthroughs. We also host the System's Reading Group (SRG), a peer-led initiative to deep-dive into foundational research. With interests spanning AI, cybersecurity, quantum computing, and more, we're always pushing boundaries through learning and discovery.",
                    themeColor: "research",
                    cassetteSvg: "/Cassette_Research.svg",
                    techIcons: [
                        { src: "/domains/research/icons8-google-colab 1.svg", alt: "Collab" },
                        { src: "/domains/research/icons8-burp-suite 1.svg", alt: "BurpSuite" },
                        { src: "/domains/research/Owasp--Streamline-Simple-Icons 1.svg", alt: "Owasp" },
                        { src: "/domains/research/LLVM 1.svg", alt: "LLVM" },
                        { src: "/domains/research/icons8-tensorflow 1.svg", alt: "TensorFlow" },
                        { src: "/domains/research/pytorch.svg", alt: "PyTorch" },
                        { src: "/domains/research/Pandas 1.svg", alt: "Pandas" },
                        { src: "/domains/research/python.svg", alt: "Python" },
                        { src: "/domains/research/qiskit 1.svg", alt: "Qiskit" }
                    ]
                },
                management: {
                    title: "MANAGEMENT",
                    description: "Leading teams and projects to success through strategic planning, effective communication, and innovative management practices.",
                    themeColor: "management",
                    cassetteSvg: "/Cassette_Management.svg",
                    techIcons: [
                        { src: "/domains/management/slack.svg", alt: "Slack" },
                        { src: "/domains/management/icons8-discord 1.svg", alt: "Discord" },
                        { src: "/domains/management/icons8-notion-512 1.svg", alt: "Notion" },
                        { src: "/domains/management/icons8-gmail 1.svg", alt: "Gmail" },
                        { src: "/domains/management/icons8-microsoft-word 1.svg", alt: "Word" },
                        { src: "/domains/management/icons8-excel-240 1.svg", alt: "Excel" }
                    ]
                }
            };

            const config = domainConfigs[domain as keyof typeof domainConfigs];
            // import { domainConfigs } from '../data/domainConfigs.js';
            if (!config) return;

            // Create domain screen HTML using DomainProjectScreen component structure
            const domainScreenHTML = createDomainScreenContent(config);

            // Insert the domain screen
            const domainScreenDiv = document.createElement('div');
            domainScreenDiv.id = 'domain-screen';
            domainScreenDiv.className = 'fixed inset-0 z-50 overflow-y-auto';
            domainScreenDiv.style.scrollbarWidth = 'none'; // Firefox
            (domainScreenDiv.style as any).msOverflowStyle = 'none'; // IE/Edge
            domainScreenDiv.innerHTML = domainScreenHTML;
            
            // Add webkit scrollbar hiding
            const style = document.createElement('style');
            style.textContent = `
                #domain-screen::-webkit-scrollbar {
                    display: none;
                }
            `;
            document.head.appendChild(style);
            
            document.body.appendChild(domainScreenDiv);

            // Smooth entrance animation with better timing
            gsap.fromTo(domainScreenDiv, 
                { 
                    opacity: 0, 
                    y: 30,
                    scale: 0.95
                },
                { 
                    opacity: 1, 
                    y: 0,
                    scale: 1,
                    duration: 0.4, 
                    ease: "power2.out",
                    delay: 0.1
                }
            );
        }

        // Function to create domain screen content
        function createDomainScreenContent(config: any) {
            // Simple theme colors
            const themeColors = {
                app: "#9B51E0",
                web: "#B4E35B", 
                design: "#FF7777",
                research: "#9AF3FF",
                management: "#008080",
                competitive: "#42CD9D"
            };

            const themeHex = themeColors[config.themeColor as keyof typeof themeColors] || themeColors.app;

            return `
                <div class="min-h-screen text-white">
                    <!-- Back Button -->
                    <div class="fixed top-6 right-6 z-50">
                        <button 
                            onclick="hideDomainScreen()"
                            class="w-12 h-12 bg-gray-800 rounded-full flex items-center justify-center hover:bg-gray-700 transition-colors border border-gray-600"
                        >
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                            </svg>
                        </button>
                    </div>

                    <!-- Hero Section with Theme Header -->
                    <div class="pt-20 pb-8 px-8">
                        <!-- Main Title Card -->
                        <div class="mx-auto max-w-6xl mb-8 relative">
                            <!-- SVG Background -->
                            <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="178" viewBox="0 0 1389 178" fill="none" class="w-full">
                                <path d="M88 1.5H1301C1348.77 1.5 1387.5 40.2274 1387.5 88V90C1387.5 137.773 1348.77 176.5 1301 176.5H88C40.2274 176.5 1.5 137.773 1.5 90V88C1.5 40.2274 40.2274 1.5 88 1.5Z" fill="${themeHex}" stroke="#FEFCD9" stroke-width="3"/>
                            </svg>
                            
                            <!-- Content overlay -->
                            <div class="absolute inset-0 flex items-center justify-center p-8">
                                <!-- Decorative Elements -->
                                <div class="absolute left-8 top-1/2 -translate-y-1/2">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 124 124" fill="none" class="animate-spin" style="animation-duration: 8s;">
                                        <circle cx="62" cy="62" r="57.5" stroke="#1E1E1E" stroke-width="3"/>
                                        <path d="M61.6582 18C67.7102 18 73.4766 19.2231 78.7246 21.4336L73.4238 30.6182L82.9629 36.126L88.2588 26.9512C97.4504 33.9379 103.81 44.4557 105.314 56.4844H94.7051V67.5H105.316C103.815 79.5413 97.4473 90.0689 88.2441 97.0586L82.9473 87.8828L73.4082 93.3906L78.709 102.572C73.4651 104.779 67.7043 106 61.6582 106C55.6035 106 49.8348 104.776 44.585 102.563L49.8945 93.3672L40.3555 87.8594L35.0527 97.0439C25.8603 90.0541 19.5005 79.5326 18 67.5H28.6123V56.4844H18.002C19.5071 44.4491 25.8735 33.9262 35.0732 26.9395L40.3721 36.1172L49.9121 30.6104L44.6094 21.4258C49.8527 19.2199 55.6129 18.0001 61.6582 18Z" fill="#1E1E1E"/>
                                    </svg>
                                </div>
                                
                                <div class="absolute right-8 top-1/2 -translate-y-1/2">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 124 124" fill="none" class="animate-spin" style="animation-duration: 8s;">
                                        <circle cx="62" cy="62" r="57.5" stroke="#1E1E1E" stroke-width="3"/>
                                        <path d="M61.6582 18C67.7102 18 73.4766 19.2231 78.7246 21.4336L73.4238 30.6182L82.9629 36.126L88.2588 26.9512C97.4504 33.9379 103.81 44.4557 105.314 56.4844H94.7051V67.5H105.316C103.815 79.5413 97.4473 90.0689 88.2441 97.0586L82.9473 87.8828L73.4082 93.3906L78.709 102.572C73.4651 104.779 67.7043 106 61.6582 106C55.6035 106 49.8348 104.776 44.585 102.563L49.8945 93.3672L40.3555 87.8594L35.0527 97.0439C25.8603 90.0541 19.5005 79.5326 18 67.5H28.6123V56.4844H18.002C19.5071 44.4491 25.8735 33.9262 35.0732 26.9395L40.3721 36.1172L49.9121 30.6104L44.6094 21.4258C49.8527 19.2199 55.6129 18.0001 61.6582 18Z" fill="#1E1E1E"/>
                                    </svg>
                                </div>

                                <!-- Domain Title -->
                                <div class="text-center">
                                    <h1 class="${config.title === "COMPETITIVE CODING" ? "text-4xl md:text-6xl" : "text-6xl md:text-8xl"} font-normal text-[#1E1E1E] tracking-wider">
                                        ${config.title}
                                    </h1>
                                </div>
                            </div>
                        </div>

                        <!-- Tech Stack Icons -->
                        ${config.techIcons.length > 0 ? `
                            <div class="flex justify-center items-center gap-8 mb-12 flex-wrap px-8">
                                ${config.techIcons.map((icon: any) => `
                                    <div class="flex items-center justify-center hover:scale-110 transition-transform duration-300">
                                        <img 
                                            src="${icon.src}" 
                                            alt="${icon.alt}" 
                                            class="w-12 h-12 md:w-12 md:h-12 grayscale hover:grayscale-0 transition-all duration-300 opacity-70 hover:opacity-100" 
                                        />
                                    </div>
                                `).join('')}
                            </div>
                        ` : ''}

                        <!-- Description -->
                        <div class="max-w-4xl mx-auto text-center mb-12">
                            <p class="text-[#FEFCD9] text-lg leading-relaxed">
                                ${config.description}
                            </p>
                        </div>

                        <!-- Projects Button -->
                        <div class="flex justify-center mb-12">
                            <button 
                                class="flex justify-center items-center w-[115px] h-[50px] rounded-[41px] border border-[#FEFCD9] text-white font-medium hover:shadow-lg transition-shadow"
                                style="background-color: ${themeHex}"
                            >
                                PROJECTS
                            </button>
                        </div>

                        <!-- Cassette SVGs -->
                        <div class="flex justify-center items-center gap-8 mb-12">
                            <div class="flex items-center justify-center">
                                <img 
                                    src="${config.cassetteSvg}" 
                                    alt="${config.title} Cassette" 
                                    class="w-48 h-auto hover:scale-105 transition-transform duration-300" 
                                />
                            </div>
                            <div class="flex items-center justify-center">
                                <img 
                                    src="/Cassette_Design.svg" 
                                    alt="Design Cassette" 
                                    class="w-48 h-auto hover:scale-105 transition-transform duration-300 opacity-60" 
                                />
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }

        // Global function to hide domain screen
        (window as any).hideDomainScreen = function() {
            const domainScreen = document.getElementById('domain-screen');
            const items = document.querySelectorAll('.domain-item');
            const subtitle = document.querySelector('.section-subtitle');
            const domainsSection = document.querySelector('.domains-section');
            
            if (domainScreen) {
                // Create smooth exit timeline
                const exitTl = gsap.timeline({
                    onComplete: () => {
                        domainScreen.remove();
                        
                        // Create smooth entrance timeline for original elements
                        const entranceTl = gsap.timeline();
                        
                        // Restore the glow ball background first
                        if (domainsSection) {
                            entranceTl.to(domainsSection, {
                                backgroundSize: 'cover',
                                opacity: 1,
                                duration: 0.3,
                                ease: "power2.out"
                            }, 0);
                        }
                        
                        // Then bring back cassettes and subtitle with stagger
                        entranceTl.to(items, {
                            opacity: 1,
                            scale: 1,
                            duration: 0.4,
                            ease: "power2.out",
                            stagger: 0.04
                        }, 0.1)
                        .to(subtitle, {
                            opacity: 1,
                            y: 0,
                            duration: 0.3,
                            ease: "power2.out"
                        }, 0.15);
                    }
                });
                
                // Smooth exit animation
                exitTl.to(domainScreen, {
                    opacity: 0,
                    y: -20,
                    scale: 0.98,
                    duration: 0.3,
                    ease: "power2.inOut"
                });
            }
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initAnimation);
        } else {
            initAnimation();
        }
    }
</script>