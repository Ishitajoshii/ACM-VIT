<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cassette Scroll Animation</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Inter, Roboto, 'Helvetica Neue', Arial, sans-serif;
            overflow-x: hidden;
        }

        /* Some content before to enable scrolling */
        .spacer {
            height: 100vh;
            background: linear-gradient(45deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 2rem;
        }

        .domains-section {
            font-family: Inter, Roboto, 'Helvetica Neue', Arial, sans-serif;
            min-height: 200vh; /* Make it taller for more scroll distance */
            padding: 5rem 0;
            background: url('/background_domains.svg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed; /* Keep background fixed */
            display: flex;
            align-items: flex-start;
            position: relative;
            overflow: hidden;
        }

        .container {
            max-width: 1400px;
            width: 100%;
            margin: 0 auto;
            padding: 0 2rem;
            position: relative;
            z-index: 2;
            padding-top: 10vh;
        }

        .section-subtitle {
            color: #fefcd9;
            text-align: center;
            font-family: 'PolySans Trial', sans-serif;
            font-size: 20.667px;
            font-weight: 400;
            margin-bottom: 4rem;
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
        }

        .domains-grid {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            align-items: center;
            max-width: 1400px;
            margin: 0 auto;
            padding: 4rem 0;
            position: relative;
            min-height: 60vh;
        }

        .domain-item {
            will-change: transform;
            transition: transform 0.1s ease-out;
            position: absolute;
        }

        .cassette-img {
            width: 308px;
            height: 188.793px;
            display: block;
            filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.3));
            transition: transform 0.3s ease;
        }

        .cassette-img:hover {
            transform: scale(1.05) rotate(2deg);
        }

        .spacer-after {
            height: 100vh;
            background: linear-gradient(45deg, #764ba2 0%, #667eea 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 2rem;
        }

        @media (max-width: 768px) {
            .container {
                padding: 0 1rem;
                padding-top: 5vh;
            }
            .cassette-img {
                width: 200px;
                height: auto;
            }
            .domains-grid {
                min-height: 40vh;
            }
        }
    </style>
</head>
<body>
    <section id="domains" class="domains-section">
        <div class="container">
            <p class="section-subtitle">
                Each domain at ACM-VIT is more than a skillset — it's a mindset.<br />
                We build, break, design, analyze, and communicate — not in silos, but in sync.<br />
                Because true innovation happens where disciplines intersect.
            </p>

            <div class="domains-grid">
                <div class="domain-item" data-speed="0.8">
                    <img src="/Cassette_App.svg" alt="App Development" class="cassette-img" />
                </div>

                <div class="domain-item" data-speed="1.2">
                    <img src="/Cassette_cc.svg" alt="Competitive Coding" class="cassette-img" />
                </div>

                <div class="domain-item" data-speed="0.5">
                    <img src="/Cassette_Design.svg" alt="Design" class="cassette-img" />
                </div>

                <div class="domain-item" data-speed="1.5">
                    <img src="/Cassette_Management.svg" alt="Management" class="cassette-img" />
                </div>

                <div class="domain-item" data-speed="0.3">
                    <img src="/Cassette_Research.svg" alt="Research" class="cassette-img" />
                </div>

                <div class="domain-item" data-speed="1.8">
                    <img src="/Cassette_Web.svg" alt="Web Development" class="cassette-img" />
                </div>
            </div>
        </div>
    </section>

    <div class="spacer-after">
        <div>Scroll up to see the reverse animation!</div>
    </div>

    <script>
		import { gsap } from 'gsap';
		import { ScrollTrigger } from 'gsap/ScrollTrigger';
        // Register ScrollTrigger plugin
        gsap.registerPlugin(ScrollTrigger);

        // Wait for DOM to load
        document.addEventListener('DOMContentLoaded', function() {
            
            // Define initial grid positions (starting positions)
            const gridPositions = [
                { x: -320, y: -100 }, // App (top-left)
                { x: 0, y: -100 },    // CC (top-center)  
                { x: 320, y: -100 },  // Design (top-right)
                { x: -320, y: 100 },  // Management (bottom-left)
                { x: 0, y: 100 },     // Research (bottom-center)
                { x: 320, y: 100 }    // Web (bottom-right)
            ];

            // Define final horizontal line positions with proper spacing
            const horizontalPositions = [
                { x: -450, y: 0 }, // App
                { x: 150, y: 0 }, // CC
                { x: 450, y: 0 }, // Design
                { x: -750, y: 0 },  // Management
                { x: -150, y: 0 },  // Research
                { x: 750, y: 0 }   // Web
            ];

            // Get all domain items in the order they appear in HTML
            const domainItems = document.querySelectorAll('.domain-item');
            
            // Set initial positions (2x3 grid)
            domainItems.forEach((item, index) => {
                const gridPos = gridPositions[index];
                gsap.set(item, { 
                    x: gridPos.x,
                    y: gridPos.y,
                    scale: 1,
                    opacity: 1
                });
            });

            // Create main timeline
            const tl = gsap.timeline({
                scrollTrigger: {
                    trigger: ".domains-grid",
                    start: "400px 80%",
                    end: "bottom center",
                    scrub: 1.5,
					pin: true, // Pin the section during the animation
                    invalidateOnRefresh: true,
                    markers: true // Uncomment for debugging
                }
            });

            // Animate each cassette to horizontal line position
            domainItems.forEach((item, index) => {
                const finalPos = horizontalPositions[index];
                const speed = parseFloat(item.dataset.speed) || 1;
                
                tl.to(item, {
                    x: finalPos.x,
                    y: finalPos.y,
                    scale: 0.85,
                    opacity: 0.9,
                    ease: "power2.inOut",
                    duration: speed
                }, 0);
            });

            // Add text animation (fade out as we scroll)
            tl.to('.section-subtitle', 
                { 
                    y: -30, 
                    opacity: 0.3,
                    duration: 1,
                    ease: "power2.out"
                }, 0
            );

            // Individual hover animations
            domainItems.forEach(item => {
                const cassette = item.querySelector('.cassette-img');
                
                item.addEventListener('mouseenter', () => {
                    gsap.to(cassette, {
                        scale: 1.1,
                        rotation: 5,
                        duration: 0.3,
                        ease: "power2.out"
                    });
                });
                
                item.addEventListener('mouseleave', () => {
                    gsap.to(cassette, {
                        scale: 1,
                        rotation: 0,
                        duration: 0.3,
                        ease: "power2.out"
                    });
                });
            });

            // Refresh ScrollTrigger
            ScrollTrigger.refresh();
        });

        // Handle window resize
        window.addEventListener('resize', () => {
            ScrollTrigger.refresh();
        });
    </script>
</body>
</html>