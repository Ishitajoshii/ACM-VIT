---
// Header.astro
---

<header
  class="fixed top-5 left-0 right-0 z-50 w-full px-4 py-2 pointer-events-none"
>
  <div
    class="relative max-w-4xl mx-auto flex justify-center pointer-events-auto"
  >
    <nav>
      <!-- Desktop nav -->
      <div class="nav-desktop">
        <div
          class="header-pill relative flex items-center justify-center w-fit px-8 overflow-hidden"
          style="height:50px;border-radius:41px;border:1px solid #FEFCD9;background:rgba(0,0,0,0.35);backdrop-filter:blur(4px);"
        >
          <!-- The Blob -->
          <div
            id="nav-blob"
            class="absolute top-0 bottom-0 bg-[#F95F4A] rounded-[41px] transition-all duration-300 ease-[cubic-bezier(0.25,0.1,0.25,1)] opacity-0 -z-10"
            style="left: 0; width: 0;"
          >
          </div>

          <!-- Dynamic Title for MORE sections -->
          <div
            id="dynamic-title"
            class="absolute inset-0 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300"
          >
            <div
              class="justify-start text-white text-base font-light font-['PolySans_Trial'] uppercase"
            >
            </div>
          </div>

          <ul
            class="nav-list relative z-10 flex items-center gap-2 md:gap-4 text-[13.5px] md:text-[14.8px] font-mono uppercase text-white"
            style="white-space:nowrap;align-items:center;letter-spacing:0.04em;"
          >
            <li>
              <a
                href="#about"
                class="nav-link inline-block px-3 py-1 hover:text-white transition-colors"
                >ABOUT</a
              >
            </li>
            <li>
              <a
                href="#domains"
                class="nav-link inline-block px-3 py-1 hover:text-white transition-colors"
                >DOMAINS</a
              >
            </li>
            <li>
              <a
                href="#projects"
                class="nav-link inline-block px-3 py-1 hover:text-white transition-colors"
                >PROJECTS</a
              >
            </li>
            <li>
              <a
                href="#events"
                class="nav-link inline-block px-3 py-1 hover:text-white transition-colors"
                >EVENTS</a
              >
            </li>
            <li>
              <a
                href="#acm-w"
                class="nav-link inline-block px-3 py-1 hover:text-white transition-colors"
                >ACM-W</a
              >
            </li>
            <li>
              <a
                href="#"
                role="button"
                class="more-toggle inline-block px-3 py-1 more-link hover:opacity-80 transition-opacity"
                aria-controls="desktopMoreMenu"
                aria-expanded="false">MORE</a
              >
            </li>
          </ul>
        </div>
      </div>

      <!-- Desktop More dropdown -->
      <div id="desktopMoreMenu" class="more-menu w-[220px]">
        <ul class="mobile-more-list">
          <li>
            <a
              href="#blogs"
              class="text-yellow-50 uppercase font-['PolySans_Trial'] text-[11px]"
              >Blogs</a
            >
          </li>
          <li>
            <a
              href="#partners"
              class="text-yellow-50 uppercase font-['PolySans_Trial'] text-[11px]"
              >Partners</a
            >
          </li>
          <li>
            <a
              href="#contact"
              class="text-yellow-50 uppercase font-['PolySans_Trial'] text-[11px]"
              >Contact Us</a
            >
          </li>
          <li>
            <a
              href="#community"
              class="text-yellow-50 uppercase font-['PolySans_Trial'] text-[11px]"
              >Community</a
            >
          </li>
          <li>
            <a
              href="#team"
              class="text-yellow-50 uppercase font-['PolySans_Trial'] text-[11px]"
              >Team</a
            >
          </li>
        </ul>
      </div>

      <!-- Mobile nav -->
      <div class="nav-mobile pt-6">
        <div
          class="w-64 min-h-7 h-auto px-3 pt-2 pb-2 rounded-3xl outline outline-[0.56px] outline-offset-[-0.56px] outline-yellow-50 inline-flex items-center justify-center"
          style="background:rgba(0,0,0,0.35);backdrop-filter:blur(4px);"
        >
          <div class="w-full inline-flex justify-center items-center gap-2">
            <a
              href="#about"
              class="justify-start text-yellow-50 text-[8px] font-light font-['PolySans_Trial'] uppercase"
              >About</a
            >
            <a
              href="#domains"
              class="justify-start text-yellow-50 text-[8px] font-light font-['PolySans_Trial'] uppercase"
              >Domains</a
            >
            <a
              href="#projects"
              class="justify-start text-yellow-50 text-[8px] font-light font-['PolySans_Trial'] uppercase"
              >Projects</a
            >
            <a
              href="#events"
              class="justify-start text-yellow-50 text-[8px] font-light font-['PolySans_Trial'] uppercase"
              >Events</a
            >
            <a
              href="#acm-w"
              class="justify-start text-yellow-50 text-[8px] font-light font-['PolySans_Trial'] uppercase"
              >ACM-W</a
            >
            <button
              type="button"
              class="more-toggle justify-start text-[#F95F4A] text-[8px] font-light font-['PolySans_Trial'] uppercase"
              aria-controls="mobileMoreMenu"
              aria-expanded="false">More</button
            >
          </div>
        </div>
        <!-- Expandable 'More' dropdown -->
        <div id="mobileMoreMenu" class="more-menu w-56">
          <ul class="mobile-more-list">
            <li>
              <a
                href="#blogs"
                class="text-yellow-50 uppercase font-['PolySans_Trial'] text-[10px]"
                >Blogs</a
              >
            </li>
            <li>
              <a
                href="#partners"
                class="text-yellow-50 uppercase font-['PolySans_Trial'] text-[10px]"
                >Partners</a
              >
            </li>
            <li>
              <a
                href="#contact"
                class="text-yellow-50 uppercase font-['PolySans_Trial'] text-[10px]"
                >Contact Us</a
              >
            </li>
            <li>
              <a
                href="#community"
                class="text-yellow-50 uppercase font-['PolySans_Trial'] text-[10px]"
                >Community</a
              >
            </li>
            <li>
              <a
                href="#team"
                class="text-yellow-50 uppercase font-['PolySans_Trial'] text-[10px]"
                >Team</a
              >
            </li>
          </ul>
        </div>
      </div>
    </nav>
  </div>
</header>

<style>
  .header-pill {
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      width 0.3s cubic-bezier(0.25, 0.1, 0.25, 1),
      background-color 0.3s ease;
  }

  /* Dynamic Mode Styles */
  .header-pill.dynamic-mode {
    width: 112px !important; /* w-28 */
    background-color: #f95f4a !important;
    border-color: #fefcd9;
  }

  .header-pill.dynamic-mode .nav-list {
    opacity: 0;
    pointer-events: none;
  }

  .header-pill.dynamic-mode #dynamic-title {
    opacity: 1;
  }

  /* Hover state for dynamic mode - revert to full menu */
  .header-pill.dynamic-mode:hover {
    width: var(--full-width, auto) !important;
    background-color: rgba(0, 0, 0, 0.35) !important;
  }

  .header-pill.dynamic-mode:hover .nav-list {
    opacity: 1;
    pointer-events: auto;
    transition-delay: 0.1s;
  }

  .header-pill.dynamic-mode:hover #dynamic-title {
    opacity: 0;
    transition-delay: 0s;
  }
  .nav-list a {
    position: relative;
    z-index: 10;
    color: #fefcd9;
    transition: color 0.3s ease;
  }
  .nav-list a.more-link {
    color: #f95f4a !important;
  }
  .nav-list li {
    white-space: nowrap;
  }
  .nav-desktop {
    display: block;
    position: relative;
  }
  .nav-mobile {
    display: none;
    position: relative;
  }

  /* 'More' dropdown */
  .more-menu {
    position: absolute;
    top: calc(100% + 8px);
    right: 0; /* stick to right */
    left: auto;
    border: 1px solid #fefcd9;
    border-radius: 16px;
    background: rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(4px);
    padding: 10px 12px;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.25);
    z-index: 60;
    /* animation base state */
    opacity: 0;
    transform: translateY(8px) scale(0.96);
    transform-origin: top right;
    transition:
      opacity 0.18s ease,
      transform 0.24s cubic-bezier(0.22, 0.61, 0.36, 1);
    pointer-events: none;
  }
  .more-menu.open,
  #desktopMoreMenu:hover {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }
  .mobile-more-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 6px;
    text-align: left;
  }
  .mobile-more-list a {
    text-decoration: none;
    letter-spacing: 0.04em;
  }
  .more-menu .mobile-more-list li {
    opacity: 0;
    transform: translateY(6px);
    transition:
      opacity 0.2s ease,
      transform 0.25s ease;
  }
  .more-menu.open .mobile-more-list li {
    opacity: 1;
    transform: translateY(0);
  }
  .more-menu.open .mobile-more-list li:nth-child(1) {
    transition-delay: 0.02s;
  }
  .more-menu.open .mobile-more-list li:nth-child(2) {
    transition-delay: 0.06s;
  }
  .more-menu.open .mobile-more-list li:nth-child(3) {
    transition-delay: 0.1s;
  }

  @media (max-width: 520px) {
    .nav-desktop {
      display: none;
    }
    .nav-mobile {
      display: block;
    }
  }
</style>

<script>
  // @ts-nocheck
  document.addEventListener("DOMContentLoaded", () => {
    // BLOB NAVIGATION LOGIC
    const blob = document.getElementById("nav-blob");
    const navLinks = document.querySelectorAll(".nav-desktop .nav-link");
    const sections = document.querySelectorAll("section[id], footer[id]"); // Include footer
    const moreToggle = document.querySelector(".nav-desktop .more-toggle");
    const pill = document.querySelector(".header-pill");
    const dynamicTitle = document.querySelector("#dynamic-title div"); // Changed to div

    // Capture initial full width for restoration
    let fullWidth = pill ? pill.offsetWidth : 0;
    if (pill) {
      pill.style.setProperty("--full-width", `${fullWidth}px`);
      // Update full width on resize
      window.addEventListener("resize", () => {
        // Temporarily remove dynamic class to measure
        const wasDynamic = pill.classList.contains("dynamic-mode");
        if (wasDynamic) pill.classList.remove("dynamic-mode");

        const navList = document.querySelector(".nav-list");
        if (navList) {
          // 32px padding-left + 32px padding-right (px-8 = 2rem = 32px)
          const w = navList.offsetWidth + 64;
          pill.style.setProperty("--full-width", `${w}px`);
        }

        if (wasDynamic) pill.classList.add("dynamic-mode");
      });
    }

    // IDs that live under the "MORE" dropdown
    const moreSectionIds = [
      "blogs",
      "partners",
      "contact",
      "community",
      "team",
    ];

    // Function to update blob position
    function updateBlob(targetLink) {
      if (!targetLink || !blob) return;

      const pill = document.querySelector(".header-pill");
      if (!pill) return;

      const pillRect = pill.getBoundingClientRect();
      const linkRect = targetLink.getBoundingClientRect();

      const relativeLeft = linkRect.left - pillRect.left;
      const width = linkRect.width;

      blob.style.left = `${relativeLeft}px`;
      blob.style.width = `${width}px`;
      blob.style.opacity = "1";
    }

    // Function to hide blob
    function hideBlob() {
      if (blob) blob.style.opacity = "0";
    }

    function setDynamicMode(isDynamic, sectionId) {
      if (!pill) return;

      if (isDynamic) {
        pill.classList.add("dynamic-mode");
        if (dynamicTitle) dynamicTitle.textContent = sectionId;
        hideBlob();
      } else {
        pill.classList.remove("dynamic-mode");
      }
    }

    // Intersection Observer to track sections
    const observerOptions = {
      root: null,
      rootMargin: "-20% 0px -60% 0px", // Trigger when section is near top/center
      threshold: 0,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute("id");

          if (id === "footer") {
            // Explicitly disable dynamic mode for footer
            setDynamicMode(false);
            hideBlob();
          } else if (moreSectionIds.includes(id)) {
            // Enter Dynamic Mode
            setDynamicMode(true, id);
          } else {
            // Exit Dynamic Mode
            setDynamicMode(false);

            // Update blob for normal sections
            const activeLink = document.querySelector(
              `.nav-desktop .nav-link[href="#${id}"]`
            );
            if (activeLink) {
              updateBlob(activeLink);
            }
          }
        }
      });
    }, observerOptions);

    sections.forEach((section) => observer.observe(section));

    // Removed manual hover listener as requested

    // EXISTING DROPDOWN LOGIC
    const toggles = Array.from(document.querySelectorAll(".more-toggle"));

    const getMenuFor = (tg) => {
      const id = tg.getAttribute("aria-controls");
      return id ? document.getElementById(id) : null;
    };

    const openMenu = (tg, menu) => {
      tg.setAttribute("aria-expanded", "true");
      menu.classList.add("open");
    };

    const closeMenu = (tg, menu) => {
      tg.setAttribute("aria-expanded", "false");
      menu.classList.remove("open");
    };

    const allMenus = () => toggles.map(getMenuFor).filter(Boolean);

    const closeAll = () =>
      toggles.forEach((tg) => {
        const m = getMenuFor(tg);
        if (m) closeMenu(tg, m);
      });

    let suppressNextDocClick = false;

    toggles.forEach((tg) => {
      const menu = getMenuFor(tg);
      if (!menu) return;
      tg.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        suppressNextDocClick = true;
        setTimeout(() => {
          suppressNextDocClick = false;
        }, 0);
        const expanded = tg.getAttribute("aria-expanded") === "true";
        toggles.forEach((ot) => {
          if (ot !== tg) {
            const otherMenu = getMenuFor(ot);
            if (otherMenu) closeMenu(ot, otherMenu);
          }
        });
        if (expanded) {
          closeMenu(tg, menu);
        } else {
          openMenu(tg, menu);
        }
      });

      let hoverTimer = null;
      const startCloseTimer = () => {
        hoverTimer = setTimeout(() => {
          closeMenu(tg, menu);
        }, 220);
      };
      const clearCloseTimer = () => {
        if (hoverTimer) {
          clearTimeout(hoverTimer);
          hoverTimer = null;
        }
      };

      tg.addEventListener("mouseenter", () => {
        openMenu(tg, menu);
      });
      tg.addEventListener("mouseleave", () => {
        startCloseTimer();
      });
      menu.addEventListener("mouseenter", () => {
        clearCloseTimer();
      });
      menu.addEventListener("mouseleave", () => {
        startCloseTimer();
      });
    });

    document.addEventListener("click", (e) => {
      if (suppressNextDocClick) return;
      const t = e.target;
      if (!(t instanceof Node)) return;
      const withinToggle = toggles.some((tg) => tg.contains(t));
      const withinMenu = allMenus().some((m) => m.contains(t));
      if (!withinToggle && !withinMenu) closeAll();
    });

    // Smooth-scroll
    document.addEventListener("click", (e) => {
      const el =
        e.target instanceof Element ? e.target.closest('a[href^="#"]') : null;
      if (!el) return;
      const href = el.getAttribute("href");
      if (!href || href.length < 2) return;
      const id = href.slice(1);
      const target = document.getElementById(id);
      if (!target) return;
      e.preventDefault();
      closeAll();
      target.scrollIntoView({ behavior: "smooth", block: "start" });
      history.replaceState(null, "", `#${id}`);

      // Manually update blob on click
      if (moreSectionIds.includes(id)) {
        setDynamicMode(true, id);
      } else {
        setDynamicMode(false);
        const link = document.querySelector(
          `.nav-desktop .nav-link[href="#${id}"]`
        );
        if (link) updateBlob(link);
      }
    });
  });
</script>
