---
import BlogsCard from "./BlogsCard.astro";

const members = [
  {
    bgurl: "/redis.svg",
  },
  {
    bgurl: "/rc.svg",
  },
  {
    bgurl: "/forktober.svg",
  },
];
---

<div
  class="flex flex-col space-y-12 md:space-y-16 items-center justify-start pt-16 md:pt-20 w-full min-h-screen"
>
  <div
    class="bg-[#F95F4A] w-11/12 rounded-full h-[10vh] md:h-[15vh] lg:h-[20vh] flex items-center justify-between px-2 md:px-8 text-stone-900 border border-[#fefcd9]"
  >
    <div
      id="rotate-svg"
      data-type="Filled"
      class="w-12 h-12 md:w-20 md:h-20 lg:w-24 lg:h-24 relative"
    >
      <img src="/rotate.svg" class="rotate-svg w-full h-full block" />
    </div>

    <div class="flex-1 flex justify-center mb-4 py-4">
      <span
        class="font-normal font-['PolySans_Trial'] text-4xl sm:text-6xl md:text-8xl lg:text-[150px]"
      >
        BLOGS
      </span>
    </div>

    <div
      data-type="Filled"
      class="w-12 h-12 md:w-20 md:h-20 lg:w-24 lg:h-24 relative"
    >
      <img src="/rotate.svg" class="rotate-svg w-full h-full block" />
    </div>
  </div>

  <div class="w-11/12 md:w-5/6 lg:w-2/3 max-w-6xl justify-start">
    <span
      class="text-[#F95F4A] text-lg md:text-2xl font-light font-['PolySans_Trial'] uppercase"
    >
      Our blogs take you behind the scenes of the technologies shaping the world today.
    </span>
    <span
      class="text-white text-lg md:text-2xl font-light font-['PolySans_Trial'] uppercase"
    >
      Whether it’s LLMs, UI/UX, microchips, or Web3, we break it down so anyone can follow. Find your next read just below.
    </span>
  </div>
  <div
    class="flex flex-col lg:flex-row justify-center items-center space-y-8 lg:space-y-0 lg:space-x-20"
  >
    <BlogsCard {...members[0]} />
    <BlogsCard {...members[1]} />
    <BlogsCard {...members[2]} />
  </div>
  <div class="flex justify-center w-full">
    <div
      class="w-full max-w-sm md:max-w-md lg:max-w-lg xl:max-w-xl px-8 py-4 rounded-[41px] border border-[#F95F4A] text-center hover:bg-[#F95F4A] hover:text-white transition-all duration-300 cursor-pointer group"
    >
      <div
        class="text-white group-hover:text-white text-base font-light font-['PolySans_Trial'] uppercase tracking-wide"
      >
        Still Curious? Dive Deeper into Our Brainwaves
      </div>
    </div>
  </div>
</div>

<script>
  import { gsap } from "gsap";
  gsap.to(".rotate-svg", {
    rotation: 360,
    repeat: -1,
    duration: 5,
    ease: "linear",
  });
</script>
