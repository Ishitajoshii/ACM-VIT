---
import BlogsCard from "./BlogsCard.astro";
import { blogData } from "../data/blogData";
import { getAssetUrl } from "../utils/cdn";
---

<div
  class="flex flex-col space-y-12 md:space-y-16 items-center justify-start pt-16 md:pt-20 w-full min-h-screen"
>
  <div
    class="bg-[#F95F4A] w-11/12 rounded-full h-[10vh] md:h-[15vh] lg:h-[20vh] flex items-center justify-between px-2 md:px-8 text-stone-900 border border-[#fefcd9]"
  >
    <div
      id="rotate-svg"
      data-type="Filled"
      class="w-12 h-12 md:w-20 md:h-20 lg:w-24 lg:h-24 relative"
    >
      <img
        src={getAssetUrl("/rotate.svg")}
        class="rotate-svg w-full h-full block"
      />
    </div>

    <div class="flex-1 flex justify-center mb-4 py-4">
      <span
        class="font-normal font-['PolySans_Trial'] text-4xl sm:text-6xl md:text-8xl lg:text-[150px]"
      >
        BLOGS
      </span>
    </div>

    <div
      data-type="Filled"
      class="w-12 h-12 md:w-20 md:h-20 lg:w-24 lg:h-24 relative"
    >
      <img
        src={getAssetUrl("/rotate.svg")}
        class="rotate-svg w-full h-full block"
      />
    </div>
  </div>

  <div class="w-11/12 md:w-5/6 lg:w-2/3 max-w-6xl justify-start">
    <span
      class="text-[#F95F4A] font-light font-['PolySans_Trial'] uppercase text-base leading-relaxed max-w-4xl max-[640px]:text-[0.88rem] max-[640px]:leading-[1.4] max-[640px]:max-w-[28rem] max-[480px]:text-[0.65rem] max-[480px]:leading-[1.35]"
    >
      Our blogs take you behind the scenes of the technologies shaping the world
      today.
    </span>
    <span
      class="text-white font-light font-['PolySans_Trial'] uppercase text-base leading-relaxed max-w-4xl max-[640px]:text-[0.88rem] max-[640px]:leading-[1.4] max-[640px]:max-w-[28rem] max-[480px]:text-[0.65rem] max-[480px]:leading-[1.35]"
    >
      Whether it’s LLMs, UI/UX, microchips, or Web3, we break it down so anyone
      can follow. Find your next read just below.
    </span>
  </div>

  <!-- Carousel Container -->
  <div class="w-full flex flex-col items-center space-y-8 relative">
    <!-- Slider Wrapper -->
    <div
      class="relative w-full max-w-[90%] md:max-w-[85%] lg:max-w-[80%] flex items-center justify-center"
    >
      <!-- Left Arrow -->
      <button
        id="prev-btn"
        class="absolute left-[-2rem] md:left-[-4rem] z-10 text-[#F95F4A] hover:text-white transition-colors duration-300"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="w-8 h-8 md:w-12 md:h-12"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15.75 19.5L8.25 12l7.5-7.5"></path>
        </svg>
      </button>

      <!-- Slider Window -->
      <div class="slider-window overflow-hidden w-full">
        <div id="blogs-track" class="flex flex-row items-center">
          {
            blogData.map((blog) => (
              <div class="blog-card-wrapper flex-shrink-0 px-2 sm:px-4">
                <BlogsCard {...blog} />
              </div>
            ))
          }
        </div>
      </div>

      <!-- Right Arrow -->
      <button
        id="next-btn"
        class="absolute right-[-2rem] md:right-[-4rem] z-10 text-[#F95F4A] hover:text-white transition-colors duration-300"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="w-8 h-8 md:w-12 md:h-12"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M8.25 4.5l7.5 7.5-7.5 7.5"></path>
        </svg>
      </button>
    </div>

    <!-- Dots -->
    <div id="dots-container" class="flex space-x-2 mt-4">
      <!-- Dots will be injected here -->
    </div>
  </div>

  <div class="flex justify-center w-full mt-8">
    <a
      href="https://blog.acmvit.in"
      target="_blank"
      rel="noopener noreferrer"
      class="w-full max-w-sm md:max-w-md lg:max-w-lg xl:max-w-xl px-8 py-4 rounded-[41px] border border-[#F95F4A] text-center hover:bg-[#F95F4A] hover:text-white transition-all duration-300 cursor-pointer group block"
    >
      <div
        class="text-white group-hover:text-white text-base font-light font-['PolySans_Trial'] uppercase tracking-wide"
      >
        Still Curious? Dive Deeper into Our Brainwaves
      </div>
    </a>
  </div>
</div>

<script>
  import { gsap } from "gsap";
  gsap.to(".rotate-svg", {
    rotation: 360,
    repeat: -1,
    duration: 5,
    ease: "linear",
  });

  const track = document.getElementById("blogs-track");
  const cards = document.querySelectorAll(".blog-card-wrapper");
  const prevBtn = document.getElementById("prev-btn");
  const nextBtn = document.getElementById("next-btn");
  const dotsContainer = document.getElementById("dots-container");

  let currentIndex = 0;
  let itemsPerPage = 3;
  let cardWidth = 0;
  let totalPages = 0;

  function updateDimensions() {
    const width = window.innerWidth;
    if (width < 640) itemsPerPage = 1;
    else if (width < 1024) itemsPerPage = 2;
    else itemsPerPage = 3;

    // Calculate card width based on the first card's width + padding
    // We assume all cards are same size.
    // The wrapper has padding, so offsetWidth includes it.
    if (cards.length > 0) {
      cardWidth = (cards[0] as HTMLElement).offsetWidth;
    }

    totalPages = Math.ceil(cards.length / itemsPerPage);
    // Ensure index is within bounds after resize
    if (currentIndex >= totalPages) currentIndex = totalPages - 1;
    if (currentIndex < 0) currentIndex = 0;

    updateSliderPosition(false); // No animation on resize
    updateDots();
  }

  function updateSliderPosition(animate = true) {
    if (!track) return;

    // Calculate the translation value
    // We slide by 'itemsPerPage' number of cards, or whatever is left
    // Actually, a simpler way for a smooth slider is to slide by 'itemsPerPage * cardWidth'
    // But since we want pages, we slide to the start of the current page.

    const xValue = -(currentIndex * itemsPerPage * cardWidth);

    // Check if we are at the end and don't have enough items to fill the page
    // In that case, we might want to clamp, but for now let's just slide.

    if (animate) {
      gsap.to(track, {
        x: xValue,
        duration: 0.5,
        ease: "power2.out",
      });
    } else {
      gsap.set(track, { x: xValue });
    }
  }

  function updateDots() {
    if (!dotsContainer) return;
    dotsContainer.innerHTML = "";
    for (let i = 0; i < totalPages; i++) {
      const dot = document.createElement("div");
      dot.classList.add(
        "w-3",
        "h-3",
        "rounded-full",
        "cursor-pointer",
        "transition-colors",
        "duration-300"
      );
      if (i === currentIndex) {
        dot.classList.add("bg-[#F95F4A]");
      } else {
        dot.classList.add("bg-gray-500", "hover:bg-[#F95F4A]");
      }
      dot.addEventListener("click", () => {
        currentIndex = i;
        updateSliderPosition();
        updateDots();
      });
      dotsContainer.appendChild(dot);
    }
  }

  if (prevBtn) {
    prevBtn.addEventListener("click", () => {
      if (currentIndex > 0) {
        currentIndex--;
      } else {
        currentIndex = totalPages - 1; // Loop to end
      }
      updateSliderPosition();
      updateDots();
    });
  }

  if (nextBtn) {
    nextBtn.addEventListener("click", () => {
      if (currentIndex < totalPages - 1) {
        currentIndex++;
      } else {
        currentIndex = 0; // Loop to start
      }
      updateSliderPosition();
      updateDots();
    });
  }

  // Initialize and handle resize
  window.addEventListener("resize", updateDimensions);

  // Wait for layout to be stable
  // Using requestAnimationFrame or setTimeout to ensure DOM is rendered
  setTimeout(() => {
    updateDimensions();
  }, 100);
</script>
