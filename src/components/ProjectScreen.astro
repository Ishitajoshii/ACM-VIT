<style>
	@font-face {
		font-family: 'PolySans Trial';
		src: url('../assets/fonts/PolySans-trial/PolySans-trial/Mono/PolySansTrial-SlimMono.otf') format('opentype');
		font-weight: 300;
		font-style: normal;
		font-display: swap;
	}

	@font-face {
		font-family: 'PolySans Trial';
		src: url('../assets/fonts/PolySans-trial/PolySans-trial/Mono/PolySansTrial-NeutralMono.otf') format('opentype');
		font-weight: 400;
		font-style: normal;
		font-display: swap;
	}

	@font-face {
		font-family: 'PolySans Trial';
		src: url('../assets/fonts/PolySans-trial/PolySans-trial/Mono/PolySansTrial-MedianMono.otf') format('opentype');
		font-weight: 500;
		font-style: normal;
		font-display: swap;
	}

	@font-face {
		font-family: 'PolySans Trial';
		src: url('../assets/fonts/PolySans-trial/PolySans-trial/Mono/PolySansTrial-BulkyMono.otf') format('opentype');
		font-weight: 700;
		font-style: normal;
		font-display: swap;
	}

	.screen {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		background: #0D0E0D;
		transition: opacity 0.8s ease, transform 0.8s ease;
	}

	.project-screen {
		z-index: 1;
	}

	.grid-layout {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 60px;
		align-items: center;
		max-width: 1400px;
		width: 100%;
		padding: 0 5%;
		height: 100%;
	}

	/* Device Section - Now on the LEFT */
	.device-section {
		display: flex;
		justify-content: center;
		align-items: center;
	}

	/* Content Section - Now on the RIGHT */
	.content-section {
		color: white;
		display: flex;
		flex-direction: column;
		gap: 30px;
		justify-content: center;
	}

	.device-container {
		perspective: 1000px;
	}

	.device-frame {
		width: 350px;
		height: 280px;
		background: #2A2A2A;
		border-radius: 20px;
		border: 3px solid #555;
		display: flex;
		flex-direction: column;
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
		overflow: hidden;
	}

	.device-header {
		height: 40px;
		background: #1A1A1A;
		display: flex;
		align-items: center;
		justify-content: center;
		border-bottom: 1px solid #555;
	}

	.header-controls {
		display: flex;
		gap: 8px;
	}

	.control-dot {
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: #666;
	}

	.device-screen {
		flex: 1;
		background: #0A0A0A;
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
	}

	.logo-display {
		display: flex;
		align-items: center;
		gap: 25px;
	}

	.logo-circle {
		width: 75px;
		height: 75px;
		border-radius: 50%;
		background: #F95F4A;
		position: relative;
		overflow: hidden;
	}

	.diagonal-pattern {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: repeating-linear-gradient(
			45deg,
			transparent,
			transparent 3px,
			#0A0A0A 3px,
			#0A0A0A 6px
		);
	}

	.logo-text {
		color: white;
		font-family: 'PolySans Trial', Arial, sans-serif;
		font-weight: bold;
		line-height: 0.8;
	}

	.acm-text {
		font-size: 44px;
		margin-bottom: 5px;
	}

	.one-text {
		font-size: 44px;
	}

	.device-footer {
		height: 50px;
		background: #1A1A1A;
		display: flex;
		align-items: center;
		justify-content: center;
		border-top: 1px solid #555;
	}

	.footer-controls {
		display: flex;
		gap: 20px;
		align-items: center;
	}

	.control-item {
		background: #666;
	}

	.circle-ctrl {
		width: 22px;
		height: 22px;
		border-radius: 50%;
	}

	.square-ctrl {
		width: 18px;
		height: 18px;
		border-radius: 3px;
	}

	.rect-ctrl {
		width: 35px;
		height: 14px;
		border-radius: 3px;
	}

	/* Content Section */
	.content-section {
		color: white;
		display: flex;
		flex-direction: column;
		gap: 50px;
		justify-content: center;
	}

	.content-block {
		border: 1px dashed #666;
		padding: 25px;
		background: rgba(0, 0, 0, 0.2);
	}

	.description {
		font-family: 'PolySans Trial', Arial, sans-serif;
		font-size: 16px;
		line-height: 1.5;
		margin: 0 0 20px 0;
		text-transform: uppercase;
		color: white;
		font-weight: 300;
		word-wrap: break-word;
	}

	.action-buttons {
		display: flex;
		gap: 18px;
		align-items: center;
	}

	.btn {
		padding: 12px 16px;
		border: 1px solid #FEFCD9;
		border-radius: 41px;
		font-family: 'PolySans Trial', Arial, sans-serif;
		font-size: 14px;
		font-weight: 300;
		text-transform: uppercase;
		cursor: pointer;
		transition: all 0.3s ease;
		word-wrap: break-word;
	}

	.btn.primary {
		background: #F95F4A;
		color: white;
	}

	.btn.icon-btn {
		background: #F95F4A;
		color: white;
		width: 44px;
		height: 44px;
		border-radius: 50%;
		border: 1px solid #FEFCD9;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0;
	}

	.btn:hover {
		transform: translateY(-3px);
		box-shadow: 0 8px 20px rgba(249, 95, 74, 0.4);
	}

	.hint-text {
		font-family: 'PolySans Trial', Arial, sans-serif;
		font-size: 13px;
		color: #888;
		text-align: center;
		opacity: 0.7;
	}

	/* Responsive Design */
	@media (max-width: 768px) {
		.grid-layout {
			grid-template-columns: 1fr;
			gap: 40px;
			padding: 20px;
		}

		.device-frame {
			width: 320px;
			height: 240px;
		}

		.logo-circle {
			width: 70px;
			height: 70px;
		}

		.acm-text, .one-text {
			font-size: 40px;
		}

		.description {
			font-size: 20px;
		}

		.project-screen {
			position: relative;
			transform: translateY(0);
			opacity: 1;
		}
	}
</style>
