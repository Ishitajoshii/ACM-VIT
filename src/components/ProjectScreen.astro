---
import Cassette from "./Cassette.astro";
export interface Props {
    projectData: {
        cassette: {
            src: string;
            alt: string;
        };
        textContent: {
            blocks: string[];
        };
        buttons: {
            primary: {
                backgroundColor: string;
                textColor: string;
                borderColor: string;
                borderRadius?: string;
            };
            learnMore: {
                text: string;
                backgroundColor: string;
                textColor: string;
                borderColor: string;
                borderRadius?: string;
            };
            visitWebsite: {
                text: string;
                backgroundColor: string;
                textColor: string;
                borderColor: string;
                borderRadius?: string;
            };
            icons: Array<{
                type: string;
                backgroundColor: string;
                textColor: string;
                borderColor: string;
                iconColor: string;
                borderRadius?: string;
            }>;
        };
        colors: {
            textColor: string;
            contentBlockBackground: string;
            hoverShadow: string;
        };
    };
}

const {projectData} = Astro.props;
