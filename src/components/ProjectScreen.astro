---
import Cassette from "./Cassette.astro";
import { getAssetUrl } from "../utils/cdn";

export interface Props {
  projects: Array<{
    cassette: {
      src: string;
      alt: string;
    };
    textContent: {
      blocks: string[];
    };
    buttons: {
      primary: {
        backgroundColor: string;
        textColor: string;
        borderColor: string;
        borderRadius?: string;
      };
      visitWebsite: {
        text: string;
        backgroundColor: string;
        textColor: string;
        borderColor: string;
        borderRadius?: string;
        url?: string;
      };
      icons: Array<{
        type: string;
        backgroundColor: string;
        textColor: string;
        borderColor: string;
        iconColor: string;
        borderRadius?: string;
        url?: string;
      }>;
    };
    colors: {
      textColor: string;
      contentBlockBackground: string;
      hoverShadow: string;
    };
  }>;
}

const { projects = [] } = Astro.props;
---

<div class="projects-container flex flex-col">
  {
    projects.map((projectData) => (
      <section
        class="hero p-[clamp(24px,4vw,48px)] text-white h-[calc(100vh-112px)] w-full"
        style={{
          "--textColor": projectData.colors.textColor,
          "--hoverShadow": projectData.colors.hoverShadow,
        }}
      >
        <div class="parent grid grid-cols-9 grid-rows-5 gap-0 h-full w-full">
          <div class="div1 col-start-1 col-end-6 row-start-1 row-end-6 flex items-center justify-center">
            <Cassette
              overlaySrc={getAssetUrl(projectData.cassette.src)}
              alt={projectData.cassette.alt}
              color={projectData.buttons.primary.backgroundColor}
            />
          </div>

          <div class="div2 col-start-6 col-end-10 row-start-1 row-end-6 border-l-2 border-r-2 border-dashed border-[#999999]/50">
            <!-- borders only -->
          </div>
          <div class="div3 col-start-1 col-end-10 row-start-3 row-end-4 border-t-2 border-b-2 border-dashed border-[#999999]/50" style="mask-image: linear-gradient(to right, transparent 45%, black 55%); -webkit-mask-image: linear-gradient(to right, transparent 45%, black 55%);">
            <!-- borders only -->
          </div>

          <div class="div4 col-start-6 col-end-10 row-start-1 row-end-3">
            <div class="content-section text-[var(--textColor)] flex flex-col gap-5 justify-center px-5 h-full">
              <div class="content-block border-none p-2.5 relative my-1">
                <p class="description font-['PolySans_Trial'] text-base leading-[1.4] m-0 uppercase text-[var(--textColor)] font-light break-words">
                  {projectData.textContent.blocks[0]}
                </p>
              </div>
            </div>
          </div>

          <div class="div5 col-start-6 col-end-10 row-start-3 row-end-4 flex items-center justify-center relative z-20">
            <div class="action-buttons flex gap-10 items-center justify-center m-0">

              <a
                href={projectData.buttons.visitWebsite.url || "#"}
                target="_blank"
                rel="noopener noreferrer"
                class="btn primary px-[18px] py-[10px] border rounded-[25px] font-['PolySans_Trial'] text-xs font-light uppercase cursor-pointer transition-all duration-300 break-words hover:-translate-y-[3px] hover:shadow-[0_8px_20px_var(--hoverShadow)] no-underline flex items-center justify-center"
                style={`
            background: ${projectData.buttons.visitWebsite.backgroundColor};
            color: ${projectData.buttons.visitWebsite.textColor};
            border-color: ${projectData.buttons.visitWebsite.borderColor};
            ${projectData.buttons.visitWebsite.borderRadius ? `border-radius: ${projectData.buttons.visitWebsite.borderRadius};` : ""}
          `}
              >
                {projectData.buttons.visitWebsite.text}
              </a>

              {projectData.buttons.icons.map((icon) => (
                <a
                  href={icon.url || "#"}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="gh-btn icon-btn w-11 h-11 rounded-full flex items-center justify-center p-0 border font-['PolySans_Trial'] text-xs font-light uppercase cursor-pointer transition-all duration-300 break-words hover:-translate-y-[3px] hover:shadow-[0_8px_20px_var(--hoverShadow)]"
                  style={`
              background: ${icon.backgroundColor};
              color: ${icon.textColor};
              border-color: ${icon.borderColor};
              ${icon.borderRadius ? `border-radius: ${icon.borderRadius};` : "border-radius: 50%;"}
            `}
                  aria-label={icon.type}
                >
                  <img
                    src={getAssetUrl(`/${icon.type}-icon.svg`)}
                    alt={icon.type}
                    width="24"
                    style={`filter: brightness(0) saturate(100%) invert(${icon.iconColor === "#FEFCD9" ? "96%" : "0%"});`}
                  />
                </a>
              ))}
            </div>
          </div>

          <div class="div6 col-start-6 col-end-10 row-start-4 row-end-6">
            <div class="content-section text-[var(--textColor)] flex flex-col gap-5 justify-center px-5 h-full">
              <div class="content-block border-none p-2.5 relative my-1">
                <p class="description font-['PolySans_Trial'] text-base leading-[1.4] m-0 uppercase text-[var(--textColor)] font-light break-words">
                  {projectData.textContent.blocks[1]}
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>
    ))
  }
</div>

<style>
  /* Local fonts removed */
</style>
```