---
export interface Props {
	projectData: {
		cassette: {
			src: string;
			alt: string;
		};
		textContent: {
			blocks: string[];
		};
		buttons: {
			primary: {
				backgroundColor: string;
				textColor: string;
				borderColor: string;
				borderRadius?: string;
			};
			learnMore: {
				text: string;
				backgroundColor: string;
				textColor: string;
				borderColor: string;
				borderRadius?: string;
			};
			visitWebsite: {
				text: string;
				backgroundColor: string;
				textColor: string;
				borderColor: string;
				borderRadius?: string;
			};
			icons: Array<{
				type: string;
				backgroundColor: string;
				textColor: string;
				borderColor: string;
				iconColor: string;
				borderRadius?: string;
			}>;
		};
		colors: {
			textColor: string;
			contentBlockBackground: string;
			hoverShadow: string;
		};
	};
}

const { projectData } = Astro.props;
---

<section class="screen project-screen" id="project-screen">
	<div class="grid-layout">
		<!-- Left Side - Cassette SVG -->
		<div class="device-section">
			<div
				style={`background-image: url(${projectData.cassette.src});`}
				class="cassette-container relative rounded-xl border border-white px-1 pt-1 bg-contain bg-center bg-no-repeat z-[100px]"
			>
				<img
					src="/casette-layout-white.svg"
					alt="Casette Boilerplate Layout"
				/>
			</div>
		</div>

		<!-- Right Side - Content -->
		<div class="content-section">
			<!-- Render text blocks dynamically -->
			{
				projectData.textContent.blocks.map((block, index) => (
					<>
						<div class="content-block">
							<p class="description">{block}</p>
						</div>

						{/* Add buttons after first block */}
						{index === 0 && (
							<div class="action-buttons">
								<button
									class="btn primary"
									style={`
									background: ${projectData.buttons.learnMore.backgroundColor};
									color: ${projectData.buttons.learnMore.textColor};
									border-color: ${projectData.buttons.learnMore.borderColor};
									${projectData.buttons.learnMore.borderRadius ? `border-radius: ${projectData.buttons.learnMore.borderRadius};` : ''}
								`}
								>
									{projectData.buttons.learnMore.text}
								</button>
								<button
									class="btn primary"
									style={`
									background: ${projectData.buttons.visitWebsite.backgroundColor};
									color: ${projectData.buttons.visitWebsite.textColor};
									border-color: ${projectData.buttons.visitWebsite.borderColor};
									${projectData.buttons.visitWebsite.borderRadius ? `border-radius: ${projectData.buttons.visitWebsite.borderRadius};` : ''}
								`}
								>
									{projectData.buttons.visitWebsite.text}
								</button>

								{/* Render icon buttons */}
								{projectData.buttons.icons.map((icon) => (
									<button
										class="gh-btn icon-btn"
										style={`
										background: ${icon.backgroundColor};
										color: ${icon.textColor};
										border-color: ${icon.borderColor};
										${icon.borderRadius ? `border-radius: ${icon.borderRadius};` : 'border-radius: 50%;'}
									`}
									>
									
										<img
											src={`/${icon.type}-icon.svg`}
											alt={icon.type}
											width="24"
											style={`filter: brightness(0) saturate(100%) invert(${icon.iconColor === "#FEFCD9" ? "96%" : "0%"});`}
										/>
									</button>
								))}
							</div>
						)}
					</>
				))
			}
		</div>
	</div>
</section>

<style
	define:vars={{
		textColor: projectData.colors.textColor,
		hoverShadow: projectData.colors.hoverShadow,
		cassetteAccent: projectData.buttons.primary.backgroundColor,
	}}
>
	@font-face {
		font-family: "PolySans Trial";
		src: url("../assets/fonts/PolySans-trial/PolySans-trial/Mono/PolySansTrial-SlimMono.otf")
			format("opentype");
		font-weight: 300;
		font-style: normal;
		font-display: swap;
	}

	@font-face {
		font-family: "PolySans Trial";
		src: url("../assets/fonts/PolySans-trial/PolySans-trial/Mono/PolySansTrial-NeutralMono.otf")
			format("opentype");
		font-weight: 400;
		font-style: normal;
		font-display: swap;
	}

	@font-face {
		family: "PolySans Trial";
		src: url("../assets/fonts/PolySans-trial/PolySans-trial/Mono/PolySansTrial-MedianMono.otf")
			format("opentype");
		font-weight: 500;
		font-style: normal;
		font-display: swap;
	}

	@font-face {
		font-family: "PolySans Trial";
		src: url("../assets/fonts/PolySans-trial/PolySans-trial/Mono/PolySansTrial-BulkyMono.otf")
			format("opentype");
		font-weight: 700;
		font-style: normal;
		font-display: swap;
	}

	.screen {
		position: relative;
		top: 0;
		left: 0;
		width: 100%;
		height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		background: transparent;
	}

	.cassette-container {
		border: 2px solid;
		border-image: linear-gradient(
				150deg,
				white 0%,
				white 50%,
				var(--cassetteAccent) 90%,
				var(--cassetteAccent) 100%
			)
			1;
		/* Use clip-path for rounded corners since border-radius doesn't work with border-image */
		clip-path: inset(0 round 12px);
	}

	.project-screen {
		z-index: 1;
		background: transparent;
	}

	.background-pattern {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: url("/background_pattern.svg");
		background-repeat: repeat;
		opacity: 0.8;
		z-index: 0;
		pointer-events: none;
	}

	.grid-layout {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 190px;
		align-items: center;
		max-width: 1200px;
		width: 100%;
		padding: 0 5%;
		height: 100%;
		position: relative;
		z-index: 1;
	}

	.device-section {
		display: flex;
		justify-content: center;
		align-items: center;
		margin-left: 30px;
	}

	.cassette-container {
		width: 100%;
		max-width: 550px;
		height: auto;
	}

	.cassette-container img {
		width: 110%;
		height: auto;
	}

	.content-section {
		color: var(--textColor);
		display: flex;
		flex-direction: column;
		gap: 20px;
		justify-content: center;
		padding-left: 20px;
		padding-right: 20px;
		
	}

	.content-block {
		border: none;
		padding: 10px;
		position: relative;
		margin: 4px 0;
	}

	.description {
		font-family: "PolySans Trial", Arial, sans-serif;
		font-size: 16px;
		line-height: 1.4;
		margin: 0;
		text-transform: uppercase;
		color: var(--textColor);
		font-weight: 300;
		word-wrap: break-word;
	}

	.action-buttons {
		display: flex;
		gap: 40px;
		align-items: center;
		justify-content: center;
		margin: 0;
	}

	.btn {
		padding: 10px 18px;
		border: 1px solid;
		border-radius: 25px;
		font-family: "PolySans Trial", Arial, sans-serif;
		font-size: 12px;
		font-weight: 300;
		text-transform: uppercase;
		cursor: pointer;
		transition: all 0.3s ease;
		word-wrap: break-word;
	}

	.gh-btn {
		border: 1px solid;
		border-radius: 25px;
		font-family: "PolySans Trial", Arial, sans-serif;
		font-size: 12px;
		font-weight: 300;
		text-transform: uppercase;
		cursor: pointer;
		transition: all 0.3s ease;
		word-wrap: break-word;
	}

	.btn.icon-btn,
	.gh-btn.icon-btn {
		width: 44px;
		height: 44px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0;
	}

	.btn:hover,
	.gh-btn:hover {
		transform: translateY(-3px);
		box-shadow: 0 8px 20px var(--hoverShadow);
	}

	/* Responsive Design */
	@media (max-width: 768px) {
		.grid-layout {
			grid-template-columns: 1fr;
			gap: 40px;
			padding: 20px;
		}

		.cassette-container {
			max-width: 220px;
		}

		.cassette-container svg {
			width: 120px !important;
		}

		.description {
			font-size: 14px;
		}

		.background-pattern {
			background-size: 80px 80px;
		}
	}

	@media (max-width: 480px) {
		.background-pattern {
			background-size: 60px 60px;
		}
	}
</style>
